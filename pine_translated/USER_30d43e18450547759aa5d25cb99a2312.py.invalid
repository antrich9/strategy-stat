import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    
    # Parameters (using defaults from Pine Script)
    atrLength = 14
    atrMultiplier = 1.5
    takeProfitRatio = 1.5
    tradeDirection = "Both"  # Can be "Long", "Short", or "Both"
    maMethod = "EMA"
    maLength1 = 6
    maLength2 = 4
    bb = 20  # lookback
    input_retSince = 2
    input_retValid = 2
    
    # Calculate Heiken Ashi
    o = df['open']
    h = df['high']
    l = df['low']
    c = df['close']
    
    haClose = (o + h + l + c) / 4
    
    haOpen = np.zeros(len(df))
    haOpen[0] = (o.iloc[0] + c.iloc[0]) / 2  # Initial open
    for i in range(1, len(df)):
        haOpen[i] = (haOpen[i-1] + haClose.iloc[i-1]) / 2
    
    haHigh = np.maximum(h, np.maximum(haOpen, haClose))
    haLow = np.minimum(l, np.minimum(haOpen, haClose))
    
    # Apply Moving Averages
    if maMethod == "EMA":
        smoothHAOpen = pd.Series(haOpen).ewm(span=maLength1, adjust=False).mean()
        smoothHAClose = pd.Series(haClose).ewm(span=maLength2, adjust=False).mean()
    else:
        smoothHAOpen = pd.Series(haOpen).rolling(maLength1).mean()
        smoothHAClose = pd.Series(haClose).rolling(maLength2).mean()
    
    smoothHAOpen = smoothHAOpen.fillna(method='bfill')
    smoothHAClose = smoothHAClose.fillna(method='bfill')
    
    # Calculate ATR
    high = df['high']
    low = df['low']
    close = df['close']
    
    tr1 = high - low
    tr2 = np.abs(high - close.shift(1))
    tr3 = np.abs(low - close.shift(1))
    tr = np.maximum(tr1, np.maximum(tr2, tr3))
    
    atr = pd.Series(tr).rolling(atrLength).mean()
    
    # Calculate pivot points
    def pivotlow(low, bb):
        pivots = np.zeros(len(low))
        for i in range(bb, len(low) - bb):
            is_pivot = True
            for j in range(1, bb + 1):
                if low.iloc[i - j] <= low.iloc[i] or low.iloc[i + j] <= low.iloc[i]:
                    is_pivot = False
                    break
            if is_pivot:
                pivots[i] = low.iloc[i]
        return pd.Series(pivots)
    
    def pivothigh(high, bb):
        pivots = np.zeros(len(high))
        for i in range(bb, len(high) - bb):
            is_pivot = True
            for j in range(1, bb + 1):
                if high.iloc[i - j] >= high.iloc[i] or high.iloc[i + j] >= high.iloc[i]:
                    is_pivot = False
                    break
            if is_pivot:
                pivots[i] = high.iloc[i]
        return pd.Series(pivots)
    
    pl = pivotlow(low, bb)
    ph = pivothigh(high, bb)
    
    # Find the most recent pivot point for each bar
    pl_series = pd.Series(np.zeros(len(df)))
    ph_series = pd.Series(np.zeros(len(df)))
    
    for i in range(len(df)):
        # Find most recent pl before or at i
        pl_vals = pl.iloc[:i+1]
        non_zero_pl = pl_vals[pl_vals > 0]
        if len(non_zero_pl) > 0:
            pl_series.iloc[i] = non_zero_pl.iloc[-1]
        
        # Find most recent ph before or at i
        ph_vals = ph.iloc[:i+1]
        non_zero_ph = ph_vals[ph_vals > 0]
        if len(non_zero_ph) > 0:
            ph_series.iloc[i] = non_zero_ph.iloc[-1]
    
    pl_series = pl_series.fillna(method='ffill')
    ph_series = ph_series.fillna(method='ffill')
    
    # Box calculations
    s_yLoc = np.where(low.shift(bb + 1) > low.shift(bb - 1), low.shift(bb - 1), low.shift(bb + 1))
    r_yLoc = np.where(high.shift(bb + 1) > high.shift(bb - 1), high.shift(bb + 1), high.shift(bb - 1))
    
    # Initialize breakout flags
    sBreak = pd.Series(np.zeros(len(df)), dtype=bool)
    rBreak = pd.Series(np.zeros(len(df)), dtype=bool)
    
    # Breakout detection
    # Support breakout: close crosses below sBot (bottom of support box)
    # Resistance breakout: close crosses above rTop (top of resistance box)
    
    sBot = pl_series  # Bottom of support box is the support pivot
    rTop = ph_series  # Top of resistance box is the resistance pivot
    
    # Detect breakouts using crossover/crossunder logic
    # cu = crossunder(close, sBot) - close crosses below support
    # co = crossover(close, rTop) - close crosses above resistance
    
    cu = (close < sBot) & (close.shift(1) >= sBot.shift(1))
    co = (close > rTop) & (close.shift(1) <= rTop.shift(1))
    
    # Update breakout flags
    for i in range(len(df)):
        if cu.iloc[i] and pd.isna(sBreak.iloc[i-1]) if i > 0 else True:
            sBreak.iloc[i] = True
        if co.iloc[i] and pd.isna(rBreak.iloc[i-1]) if i > 0 else True:
            rBreak.iloc[i] = True
        
        # Reset if pivot changes
        if pl.iloc[i] > 0:
            sBreak.iloc[i] = False
        if ph.iloc[i] > 0:
            rBreak.iloc[i] = False
    
    # Retest conditions
    # Long retest (sRetValid): after sBreak, price pulls back to support
    # Short retest (rRetValid): after rBreak, price pulls back to resistance
    
    # Calculate retest conditions
    # s1-s4 for long entries, r1-r4 for short entries
    
    sTop = pl_series  # Top of support box
    sBot = pl_series.shift(-1)  # Bottom of support box (next pivot)
    
    # Recalculate sTop and sBot properly based on the box top and bottom
    sTop = np.where(low.shift(bb + 1) > low.shift(bb - 1), low.shift(bb - 1), low.shift(bb + 1))
    sBot = pl_series
    
    rBot = np.where(high.shift(bb + 1) > high.shift(bb - 1), high.shift(bb + 1), high.shift(bb - 1))
    rTop = ph_series
    
    # Long retest conditions
    s1 = sBreak & (high >= sTop) & (close <= sBot)
    s2 = sBreak & (high >= sTop) & (close >= sBot) & (close <= sTop)
    s3 = sBreak & (high >= sBot) & (high <= sTop)
    s4 = sBreak & (high >= sBot) & (high <= sTop) & (close < sBot)
    
    # Short retest conditions
    r1 = rBreak & (low <= rBot) & (close >= rTop)
    r2 = rBreak & (low <= rBot) & (close <= rTop) & (close >= rBot)
    r3 = rBreak & (low <= rTop) & (low >= rBot)
    r4 = rBreak & (low <= rTop) & (low >= rBot) & (close > rTop)
    
    # Combine retest conditions
    sRetValid = s1 | s2 | s3 | s4
    rRetValid = r1 | r2 | r3 | r4
    
    # Track when retest events occur
    retestActive = pd.Series(np.zeros(len(df)), dtype=bool)
    
    for i in range(len(df)):
        if sRetValid.iloc[i] or rRetValid.iloc[i]:
            retestActive.iloc[i] = True
    
    # Generate entries
    entries = []
    trade_num = 0
    
    for i in range(len(df)):
        if i < bb:  # Skip first bb bars for lookback
            continue
        
        # Long entry
        if (tradeDirection in ["Long", "Both"]) and sRetValid.iloc[i]:
            trade_num += 1
            entry = {
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': df['time'].iloc[i],
                'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                'entry_price_guess': close.iloc[i],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': close.iloc[i],
                'raw_price_b': close.iloc[i]
            }
            entries.append(entry)
        
        # Short entry
        if (tradeDirection in ["Short", "Both"]) and rRetValid.iloc[i]:
            trade_num += 1
            entry = {
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': df['time'].iloc[i],
                'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                'entry_price_guess': close.iloc[i],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': close.iloc[i],
                'raw_price_b': close.iloc[i]
            }
            entries.append(entry)
    
    return entries

I'm completing the ATR calculation by taking the Wilder smoothing approach with a simple moving average. Then I set up the pivot point logic to identify swing highs and lows based on the lookback parameter, using forward and backward searches through the price series.

For each bar, I track the most recent pivot point by finding all non-zero values up to the current index and selecting the last one. If no pivots exist yet, I use the initial values. Once pivots are established, I calculate the box boundaries by comparing the high and low prices shifted by the lookback period to determine the support and resistance levels.

The breakout detection logic initializes flags and checks for crossovers and crossunders relative to the box boundaries. When a breakout occurs and the previous flag wasn't set, the current flag becomes true. The flags reset whenever a new pivot point is detected.

For the retest conditions, I'm evaluating multiple scenarios based on whether a breakout has occurred: checking if the high reaches the top of the box while the close stays below the bottom, or if the high touches the bottom boundary with the close between the box extremes.

The combined retest validity checks whether any of these four conditions are met for both long and short scenarios. Then I'm tracking entry signals by iterating through the data, skipping the initial lookback period, and when a valid retest occurs, creating an entry record with trade number, direction, timestamp, and other metadata before returning the accumulated entries. I'm implementing the Wilder RSI calculation, which uses an exponential weighted moving average approach instead of simple smoothing.

