    # Pivot calculations
    pl = pd.Series(np.nan, index=df.index)
    ph = pd.Series(np.nan, index=df.index)
    
    for i in range(bb, len(df) - bb):
        is_pl = True
        for j in range(1, bb + 1):
            if low.iloc[i - j] <= low.iloc[i] or low.iloc[i + j] <= low.iloc[i]:
