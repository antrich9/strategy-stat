    r2 = rBreak_active & (low <= rBot) & (close <= rTop) & (close >= rBot)
    r3 = rBreak_active & (low <= rTop) & (low >= rBot)
    r4 = rBreak_active & (low <= rTop) & (low >= rBot) & (close > rTop)
    
    # Combine retests
    sRetValid = s1 | s2 | s3 | s4
    rRetValid = r1 | r2 | r3 | r4
    
    # Calculate bars since breakout
    bars_since_sBreak = pd.Series(np.nan, index=df.index)
    bars_since_rBreak = pd.Series(np.nan, index=df.index)
    
    for i in range(len(df)):
        if pd.notna(sBreak.iloc[i]) and sBreak.iloc[i]:
            bars_since_sBreak.iloc[i] = 0
        elif i > 0 and pd.notna(bars_since_sBreak.iloc[i-1]):
            bars_since_sBreak.iloc[i] = bars_since_sBreak.iloc[i-1] + 1
        
        if pd.notna(rBreak.iloc[i]) and rBreak.iloc[i]:
            bars_since_rBreak.iloc[i] = 0
        elif i > 0 and pd.notna(bars_since_rBreak.iloc[i-1]):
            bars_since_rBreak.iloc[i] = bars_since_rBreak.iloc[i-1] + 1
    
    # Final entry conditions
    long_entry = sRetValid & (bars_since_sBreak >= input_retSince) & (bars_since_sBreak <= input_retValid)
    short_entry = rRetValid & (bars_since_rBreak >= input_retSince) & (bars_since_rBreak <= input_retValid)
    
    # Filter by trade direction
    if tradeDirection == "Long":
        short_entry = pd.Series(False, index=df.index)
    elif tradeDirection == "Short":
        long_entry = pd.Series(False, index=df.index)
    
    # Generate entries
    entries = []
    trade_num = 0
    
    for i in range(len(df)):
        if i < bb:
            continue
        
        entry_price = close.iloc[i]
        
        if long_entry.iloc[i]:
            trade_num += 1
            ts = df['time'].iloc[i]
            entries.append({
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': ts,
                'entry_time': datetime.fromtimestamp(ts, tz=timezone.utc).isoformat(),
                'entry_price_guess': entry_price,
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': entry_price,
                'raw_price_b': entry_price
            })
        
        if short_entry.iloc[i]:
            trade_num += 1
            ts = df['time'].iloc[i]
            entries.append({
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': ts,
                'entry_time': datetime.fromtimestamp(ts, tz=timezone.utc).isoformat(),
                'entry_price_guess': entry_price,
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': entry_price,
                'raw_price_b': entry_price
            })
    
    return entries

I need to verify the ATR calculation and ensure the breakout detection handles the repainting logic correctly. Looking at the function structure, it's checking retest conditions after a breakout occurs, calculating bars since the event, and validating against the retest detection threshold. The function uses repaint logic to determine when conditions are met based on the input parameter, then tracks retOccurred to prevent duplicate entries. The key is tracking the breakout state, counting bars since it occurred, and applying the appropriate price condition check based on the repaint setting. The breakLabel function draws a label when a breakout occurs. Looking at the logic flow, sBreak is set true when cu fires (support breakout), then the system checks for retests. The retest event function monitors s1-s4 conditions and returns sRetValid when conditions align.

The entry logic appears to be: when sBreak activates and sRetValid triggers, that's a long entry signal. The system waits for the retest confirmation before entering a position. For short entries, rBreak (resistance breakout) followed by rRetValid generates the signal.

Looking more carefully at the structure, I need to verify the exact trigger conditions in the retest function. The logic checks if retActive changes state, then validates price movement against the breakout level depending on whether it's a pivot high or low type. The retValid condition combines timing (bars since event within threshold) with price confirmation and ensuring no prior occurrence.

For implementation, I'll track when sRetValid or rRetValid signals fire, since these incorporate the barssince check and repaint logic. Entries will trigger based on whichever direction's signal is active.

import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    atrLength = 14
    atrMultiplier = 1.5
    takeProfitRatio = 1.5
    tradeDirection = "Both"
    maMethod = "EMA"
    maLength1 = 6
    maLength2 = 4
    bb = 20
    input_retSince = 2
    input_retValid = 2
    input_repType = 'On'
    
    o = df['open'].copy()
    h = df['high'].copy()
    l = df['low'].copy()
    c = df['close'].copy()
    
    # Heiken Ashi
    haClose = (o + h + l + c) / 4
    haOpen = pd.Series(index=df.index, dtype=float)
    haOpen.iloc[0] = (o.iloc[0] + c.iloc[0]) / 2
    for i in range(1, len(df)):
        prev_ha_close = haClose.iloc[i-1] if pd.notna(haClose.iloc[i-1]) else (o.iloc[i-1] + h.iloc[i-1] + l.iloc[i-1] + c.iloc[i-1]) / 4
        haOpen.iloc[i] = (haOpen.iloc[i-1] + prev_ha_close) / 2
    
    haHigh = pd.concat([h, haOpen, haClose], axis=1).max(axis=1)
    haLow = pd.concat([l, haOpen, haClose], axis=1).min(axis=1)
    
    # Moving averages applied to HA values
    if maMethod == "EMA":
        smoothHAOpen = haOpen.ewm(span=maLength1, adjust=False).mean()
        smoothHAClose = haClose.ewm(span=maLength2, adjust=False).mean()
    else:
        smoothHAOpen = haOpen.rolling(maLength1).mean()
        smoothHAClose = haClose.rolling(maLength2).mean()
    
    # ATR calculation using Wilder's method
    high = h
    low = l
    close = c
    
    tr1 = high - low
    tr2 = high - close.shift()
    tr3 = low - close.shift()
    tr = tr1.combine_first(tr2.abs()).combine_first(tr3.abs()).clip(lower=0)
    
    atr = tr.ewm(alpha=1/atrLength, adjust=False).mean()
    
    # Pivot points for support and resistance
    pl = pd.Series(np.nan, index=df.index)
    ph = pd.Series(np.nan, index=df.index)