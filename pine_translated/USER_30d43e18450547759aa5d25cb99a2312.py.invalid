                is_ph = False
                break
        if is_ph:
            ph.iloc[i] = high.iloc[i]
    
    pl = pl.fillna(method='ffill')
    ph = ph.fillna(method='ffill')
    
    s_yLoc = pd.Series(np.where(low.shift(bb + 1) > low.shift(bb - 1), low.shift(bb - 1), low.shift(bb + 1)), index=df.index)
    r_yLoc = pd.Series(np.where(high.shift(bb + 1) > high.shift(bb - 1), high.shift(bb + 1), high.shift(bb - 1)), index=df.index)
    
    # Box top and bottom
    sTop = pd.Series(np.where(low.shift(bb + 1) > low.shift(bb - 1), low.shift(bb - 1), low.shift(bb + 1)), index=df.index)
