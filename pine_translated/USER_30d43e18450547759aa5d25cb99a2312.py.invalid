    maMethod = "EMA"
    maLength1 = 6
    maLength2 = 4
    bb = 20  # lookback
    input_retSince = 2
    input_retValid = 2
    input_repType = 'On'
    
    o = df['open'].copy()
    h = df['high'].copy()
    l = df['low'].copy()
    c = df['close'].copy()
    
