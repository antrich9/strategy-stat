import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    
    n = len(df)
    length = 20
    cross_confirm = True
    use_ttis = True
    inverse = True
    red_green = True
    highlight_movements = True
    
    if n < length:
        return []
    
    close = df['close']
    high = df['high']
    low = df['low']
    
    # Bollinger Bands (length=20)
    BB_basis = close.rolling(length).mean()
    dev = close.rolling(length).std()
    BB_upper = BB_basis + 2.0 * dev
    BB_lower = BB_basis - 2.0 * dev
    
    # Keltner Channels (length=20)
    KC_basis = close.rolling(length).mean()
    dev_kc = close.rolling(length).mean()
    KC_upper_low = KC_basis + dev_kc * 2.0
    KC_lower_low = KC_basis - dev_kc * 2.0
    
    # No squeeze condition
    NoSqz = (BB_lower < KC_lower_low) | (BB_upper > KC_upper_low)
    
    # Linear Regression for momentum
    highest = high.rolling(length).max()
    lowest = low.rolling(length).min()
    sma_close = close.rolling(length).mean()
    avg = (highest + lowest + sma_close) / 3.0
    price_deviation = close - avg
    
    # Calculate linear regression slope for each bar
    mom = pd.Series(np.nan, index=df.index)
    x = np.arange(length)
    
    for i in range(length - 1, n):
        window = price_deviation.iloc[i - length + 1:i + 1]
        mom.iloc[i] = np.polyfit(x, window, 1)[0]
    
    # Rising momentum
    prev_mom = mom.shift(1).fillna(0)
    rising = (mom > prev_mom) & (mom > 0)
    
    # Cross signals
    cross_long = pd.Series(False, index=df.index)
    cross_short = pd.Series(False, index=df.index)
    
    for i in range(1, n):
        if pd.isna(mom.iloc[i]):
            continue
        # Long cross: mom just turned positive and rising
        cross_long.iloc[i] = (mom.iloc[i] > 0) and not (prev_mom.iloc[i] > 0 and rising.iloc[i-1])
        # Short cross: mom just turned negative and falling
        cross_short.iloc[i] = (mom.iloc[i] < 0) and not (prev_mom.iloc[i] < 0 and (mom.iloc[i] < mom.iloc[i-1]))
    
    # Final signals with inverse
    if use_ttis and inverse:
        long_signal = cross_short & NoSqz
        short_signal = cross_long & NoSqz
    else:
        long_signal = cross_long & NoSqz
        short_signal = cross_short & NoSqz
    
    # Generate entries
    entries = []
    trade_num = 1
    
    for i in range(1, n):
        if pd.isna(mom.iloc