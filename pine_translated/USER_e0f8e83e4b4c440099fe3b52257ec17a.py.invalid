import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    
    # Resample to 4H timeframe
    df['time'] = pd.to_datetime(df['time'], unit='s', utc=True)
    df_4h = df.set_index('time').resample('4h').agg({
        'open': 'first',
        'high': 'max',
        'low': 'min',
        'close': 'last',
        'volume': 'sum'
    }).dropna()
    
    # Calculate 4H indicators
    high_4h = df_4h['high']
    low_4h = df_4h['low']
    close_4h = df_4h['close']
    volume_4h = df_4h['volume']
    
    # Volume filter
    volfilt1 = volume_4h.shift(1) > volume_4h.rolling(9).mean() * 1.5
    
    # ATR filter
    tr = np.maximum(high_4h - low_4h, np.maximum(
        np.abs(high_4h - close_4h.shift(1)),
        np.abs(low_4h - close_4h.shift(1))
    ))
    atr_4h = tr.rolling(20).mean() / 1.5
    atrfilt1 = (low_4h - high_4h.shift(2) > atr_4h) | (low_4h.shift(2) - high_4h > atr_4h)
    
    # Trend filter
    loc1 = close_4h.rolling(54).mean()
    loc2 = loc1 > loc1.shift(1)
    locfiltb1 = loc2
    locfilts1 = ~loc2
    
    # FVG detection on 4H
    bfvg1 = (low_4h > high_4h.shift(2)) & volfilt1 & atrfilt1 & locfiltb1
    sfvg1 = (high_4h < low_4h.shift(2)) & volfilt1 & atrfilt1 & locfilts1
    
    # Trading windows (check if 4H bar overlaps with window)
    # Window 1: 07:00-11:45, Window 2: 14:00-14:45
    df_4h = df_4h.copy()
    df_4h['hour'] = df_4h.index.hour
    df_4h['minute'] = df_4h.index.minute
    df_4h['window1'] = ((df_4h['hour'] == 7) | ((df_4h['hour'] >= 8) & (df_4h['hour'] < 12))) | ((df_4h['hour'] == 11) & (df_4h['minute'] <= 45))
    df_4h['window2'] = (df_4h['hour'] == 14) & (df_4h['minute'] <= 45)
    df_4h['in_window'] = df_4h['window1'] | df_4h['window2']
    
    # Detect new 4H bars
    df_4h['is_new_4h'] = True  # All resampled bars are new
    
    # Sharp turn detection with state tracking
    entries = []
    trade_num = 1
    lastFVG = 0
    
    for i in range(1, len(df_4h)):
        row = df_4h.iloc[i]
        
        if not row['in_window']:
            continue
        
        # Update lastFVG state
        if bfvg1.iloc[i]:
            lastFVG = 1
        elif sfvg1.iloc[i]:
            lastFVG = -1
        
        # Check for sharp turn entries
        if bfvg1.iloc[i] and lastFVG == -1:
            entries.append({
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': int(row.name.timestamp()),
                'entry_time': row.name.isoformat(),
                'entry_price_guess': row['close'],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': row['close'],
                'raw_price_b': row['close']
            })
            trade_num += 1
            lastFVG = 1
        
        elif sfvg1.iloc[i] and lastFVG == 1:
            entries.append({
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': int(row.name.timestamp()),
                'entry_time': row.name.isoformat(),
                'entry_price_guess': row['close'],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': row['close'],
                'raw_price_b': row['close']
            })
            trade_num += 1
            lastFVG = -1
    
    return entries

I'm tracking the last FVG state to identify sharp turn patterns—when a bullish FVG follows a bearish one or vice versa. Each entry captures the trade number, direction, timestamp, and price. The state updates after each FVG detection, allowing me to detect the reversal patterns that signal potential entries. I need to complete the is_new_4h logic and reconsider the entry timing. In Pine Script, entries occur when a 4H bar closes and confirms a sharp turn pattern. Since I'm working with closed bars in Python, every 4H bar is already closed, so is_new_4h should be True for all bars. This means the bar_index check is just confirming we're on a valid 4H bar.

