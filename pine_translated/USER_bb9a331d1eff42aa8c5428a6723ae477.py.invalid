import pandas as pd
import numpy as np
from datetime import datetime, timezone

def alma(data, length, offset, sigma):
    """Arnaud Legoux Moving Average"""
    window = np.arange(length)
    w = np.exp(-(window - offset * (length - 1))**2 / (2 * sigma**2))
    w = w / w.sum()
    
    result = np.full(len(data), np.nan)
    for i in range(length - 1, len(data)):
        result[i] = np.sum(data[i - length + 1:i + 1] * w)
    return pd.Series(result, index=data.index)

def generate_entries(df: pd.DataFrame) -> list:
    close = df['close']
    high = df['high']
    low = df['low']
    
    # JMA Parameters
    lengthjmaJMA = 7
    phasejmaJMA = 50
    powerjmaJMA = 2
    srcjmaJMA = close
    
    phasejmaJMARatiojmaJMA = 0.5 if phasejmaJMA < -100 else 2.5 if phasejmaJMA > 100 else phasejmaJMA / 100 + 1.5
    betajmaJMA = 0.45 * (lengthjmaJMA - 1) / (0.45 * (lengthjmaJMA - 1) + 2)
    alphajmaJMA = betajmaJMA ** powerjmaJMA
    
    e0JMA = np.zeros(len(df))
    e1JMA = np.zeros(len(df))
    e2JMA = np.zeros(len(df))
    jmaJMA = np.zeros(len(df))
    
    e0JMA[0] = srcjmaJMA.iloc[0]
    for i in range(1, len(df)):
        e0JMA[i] = (1 - alphajmaJMA) * srcjmaJMA.iloc[i] + alphajmaJMA * e0JMA[i-1]
        e1JMA[i] = (srcjmaJMA.iloc[i] - e0JMA[i]) * (1 - betajmaJMA) + betajmaJMA * e1JMA[i-1]
        e2JMA[i] = (e0JMA[i] + phasejmaJMARatiojmaJMA * e1JMA[i] - jmaJMA[i-1]) * (1 - alphajmaJMA) ** 2 + alphajmaJMA ** 2 * e2JMA[i-1]
        jmaJMA[i] = e2JMA[i] + jmaJMA[i-1]
    
    signalmaJMALong = (close > jmaJMA).values
    signalmaJMAShort = (close < jmaJMA).values

I'm computing the Jurik Moving Average components iteratively, where each iteration builds on the previous values. The signal conditions compare the closing price against the JMA to determine directional bias.

