def _atr(df, length):
    high = df['high']
    low = df['low']
    close = df['close']
    tr1 = high - low
    tr2 = abs(high - close.shift(1))
    tr3 = abs(low - close.shift(1))
    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
    alpha = 1/length
    atr = tr.ewm(alpha=alpha, adjust=False).mean()
    return atr