tr1 = df['high'] - df['low']
        tr2 = df['high'] - df['close'].shift(1)
        tr3 = df['low'] - df['close'].shift(1)
        tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
        # Wilder ATR
        atr = tr.ewm(alpha=1/100, adjust=False).mean() # ewm with alpha=1/len is Wilder's ATR
        # Wait, Pine ATR(100) uses RMA(TR, 100). RMA is equivalent to EMA with alpha=1/len.