import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    bb = 20  # lookback range (default from input_lookback)
    input_retSince = 2  # bars since breakout (default from input_retSince)
    input_retValid = 2  # retest detection limiter (default from input_retValid)
    trade_direction = "Both"
    
    # Calculate pivot points (pivothigh, pivotlow)
    pl = df['low'].rolling(window=bb+1, min_periods=bb+1).min().shift(bb)
    ph = df['high'].rolling(window=bb+1, min_periods=bb+1).max().shift(bb)
    
    # Box levels (sBot, sTop, rBot, rTop)
    s_yLoc = np.where(df['low'].shift(bb+1) > df['low'].shift(bb-1), df['low'].shift(bb-1), df['low'].shift(bb+1))
    r_yLoc = np.where(df['high'].shift(bb+1) > df['high'].shift(bb-1), df['high'].shift(bb+1), df['high'].shift(bb-1))
    
    sBot = pl
    sTop = s_yLoc
    rBot = ph
    rTop = r_yLoc
    
    # Detect pivot changes
    pl_change = (df['low'].rolling(window=2, min_periods=2).min().shift(1) != pl) | (pl != pl.shift(1))
    ph_change = (df['high'].rolling(window=2, min_periods=2).max().shift(1) != ph) | (ph != ph.shift(1))
    
    # Support box
    sBreak = pd.Series(False, index=df.index)
    sBreak_update = pd.Series(False, index=df.index)
    
    for i in range(bb+1, len(df)):
        if pd.notna(pl.iloc[i]):
            sBreak_update.iloc[i] = True
        if pl_change.iloc[i]:
            sBreak_update.iloc[i] = False
    
    # Resistance box
    rBreak = pd.Series(False, index=df.index)
    rBreak_update = pd.Series(False, index=df.index)
    
    for i in range(bb+1, len(df)):
        if pd.notna(ph.iloc[i]):
            rBreak_update.iloc[i] = True
        if ph_change.iloc[i]:
            rBreak_update.iloc[i] = False
    
    return sBreak, rBreak

