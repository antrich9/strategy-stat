import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    # Settings
    fvgTH = 0.5  # Fair Value Gap Width Filter
    
    # Calculate ATR(144) for FVG filtering
    tr1 = np.maximum(df['high'] - df['low'], 
                     np.maximum(np.abs(df['high'] - df['close'].shift(1)),
                                np.abs(df['low'] - df['close'].shift(1))))
    atr = tr1.ewm(span=144, adjust=False).mean()
    fvg_filter = atr * fvgTH
    
    # FVG detection
    # bullG = low > high[1] (bullish gap up)
    bullG = df['low'] > df['high'].shift(1)
    # bearG = high < low[1] (bearish gap down)
    bearG = df['high'] < df['low'].shift(1)
    
    # Bullish FVG: (low - high[2]) > atr AND low > high[2] AND close[1] > high[2] AND not (bullG OR bullG[1])
    bull = ((df['low'] - df['high'].shift(2)) > fvg_filter) & \
           (df['low'] > df['high'].shift(2)) & \
           (df['close'].shift(1) > df['high'].shift(2)) & \
           ~(bullG | bullG.shift(1))
    
    # Bearish FVG: (low[2] - high) > atr AND high < low[2] AND close[1] < low[2] AND not (bearG OR bearG[1])
    bear = ((df['low'].shift(2) - df['high']) > fvg_filter) & \
           (df['high'] < df['low'].shift(2)) & \
           (df['close'].shift(1) < df['low'].shift(2)) & \
           ~(bearG | bearG.shift(1))
    
    # Track bull/bear FVG state using shift to capture prior bar values
    bullFvgUpper = pd.Series(np.where(bull, df['high'].shift(2), np.nan), index=df.index)
    bullFvgLower = pd.Series(np.where(bull, df['low'], np.nan), index=df.index)
    bearFvgUpper = pd.Series(np.where(bear, df['high'], np.nan), index=df.index)
    bearFvgLower = pd.Series(np.where(bear, df['low'].shift(2), np.nan), index=df.index)
    
    # Calculate midpoints for both FVG types
    bullMidpoint = (bullFvgUpper + bullFvgLower) / 2
    bearMidpoint = (bearFvgUpper + bearFvgLower) / 2
    
    # Flag logic for detecting when FVG boundaries are broken
    prevDayHigh = df['high'].shift(1)  # Previous day's high
    prevDayLow = df['low'].shift(1)    # Previous day's low
    
    prevDayHighTaken = df['high'] > prevDayHigh
    prevDayLowTaken = df['low'] < prevDayLow
    
    flagpdh = pd.Series(False, index=df.index)
    flagpdl = pd.Series(False, index=df.index)
    
    # Initialize flags on first valid bar
    flagpdh.iloc[0] = prevDayHighTaken.iloc[0] if not pd.isna(prevDayHighTaken.iloc[0]) else False
    flagpdl.iloc[0] = prevDayLowTaken.iloc[0] if not pd.isna(prevDayLowTaken.iloc[0]) else False
    
    # Track state changes for both flags across all bars
    for i in range(1, len(df)):
        if prevDayHighTaken.iloc[i]:
            flagpdh.iloc[i] = True
            flagpdl.iloc[i] = False
        elif prevDayLowTaken.iloc[i]:
            flagpdl.iloc[i] = True
            flagpdh.iloc[i] = False
        else:
            flagpdh.iloc[i] = flagpdh.iloc[i-1]
            flagpdl.iloc[i] = flagpdl.iloc[i-1]
    
    # Extract hour and minute components from timestamps for time-based filtering
    dt = pd.to_datetime(df['time'], unit='s', utc=True)
    hour = dt.dt.hour
    minute = dt.dt.minute
    total_minutes = hour * 60 + minute
    
    # Define trading windows (morning: 07:45-09:45, afternoon: 14:45-16:45)
    isWithinMorningWindow = (total_minutes >= 7 * 60 + 45) & (total_minutes < 9 * 60 + 45)
    isWithinAfternoonWindow = (total_minutes >= 14 * 60 + 45) & (total_minutes < 16 * 60 + 45)
    in_trading_window = isWithinMorningWindow | isWithinAfternoonWindow
    
    # Calculate crossover and crossunder signals between price and FVG midpoints
    # Bullish crossunder: price crosses below bull midpoint
    crossunder_bull = (df['low'] < bullMidpoint) & (df['low'].shift(1) >= bullMidpoint.shift(1))
    # Bearish crossover: price crosses above bear midpoint  
    crossover_bear = (df['high'] > bearMidpoint) & (df['high'].shift(1) <= bearMidpoint.shift(1))
    
    # Track FVG state: last=True for bullish, last=False for bearish
    last = pd.Series(False, index=df.index)
    in_trend = bull | bear
    for i in range(len(df)):
        if bull.iloc[i]:
            last.iloc[i] = True
        elif bear.iloc[i]:
            last.iloc[i] = False
        elif i > 0 and in_trend.iloc[i]:
            last.iloc[i] = last.iloc[i-1]
    
    # Detect FVG formations (similar to bar_index logic)
    bull_fvg = bull.iloc[2:]

 bulls = (df['low'] - df['high'].shift(2)) > fvg_filter
    bullG = df['low'] > df['high'].shift(1)
    bullFVG = bulls & (df['low'] > df['high'].shift(2)) & (df['close'].shift(1) > df['high'].shift(2)) & ~(bullG | bullG.shift(1))
    
    bears = (df['low'].shift(2) - df['high']) > fvg_filter
    bearG = df['high'] < df['low'].shift(1)
    bearFVG = bears & (df['high'] < df['low'].shift(2)) & (df['close'].shift(1) < df['low'].shift(2)) & ~(bearG | bearG.shift(1))
    
    bullFvgUpper = pd.Series(np.nan, index=df.index)
    bullFvgLower = pd.Series(np.nan, index=df.index)
    bearFvgUpper = pd.Series(np.nan, index=df.index)
    bearFvgLower = pd.Series(np.nan, index=df.index)
    
    bullFvgUpper[bullFVG] = df['high'].shift(2)[bullFVG]
    bullFvgLower[bullFVG] = df['low'][bullFVG]
    bearFvgUpper[bearFVG] = df['high'][bearFVG]
    bearFvgLower[bearFVG] = df['low'].shift(2)[bearFVG]
    
    bullFvgUpper = bullFvgUpper.ffill()
    bullFvgLower = bullFvgLower.ffill()
    bearFvgUpper = bearFvgUpper.ffill()
    bearFvgLower = bearFvgLower.ffill()
    
    bullMidpoint = (bullFvgUpper + bullFvgLower) / 2
    bearMidpoint = (bearFvgUpper + bearFvgLower) / 2

