def generate_entries(df: pd.DataFrame) -> list:
    multiplier = 3.0
    atrLength = 10
    
    # Calculate True Range
    high = df['high']
    low = df['low']
    close = df['close']
    
    # Previous close
    prev_close = close.shift(1)
    
    # True Range
    tr1 = high - low
    tr2 = (high - prev_close).abs()
    tr3 = (low - prev_close).abs()
    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
    
    # Wilder ATR
    atr = tr.ewm(alpha=1.0/atrLength, adjust=False).mean()
    
    # Supertrend calculation
    hl2 = (high + low) / 2
    upper_band = hl2 + multiplier * atr
    lower_band = hl2 - multiplier * atr
    
    # Initialize
    trend = pd.Series(index=df.index, dtype=float)
    final_upper = upper_band.copy()
    final_lower = lower_band.copy()
    
    # First bar
    if len(df) > 0:
        trend.iloc[0] = 0  # neutral or unknown
        # Initialize final bands
        final_upper.iloc[0] = upper_band.iloc[0]
        final_lower.iloc[0] = lower_band.iloc[0]
    
    # Iterate from second bar
    for i in range(1, len(df)):
        if pd.isna(atr.iloc[i]):
            trend.iloc[i] = trend.iloc[i-1] if i > 0 else 0
            final_upper.iloc[i] = final_upper.iloc[i-1] if i > 0 else upper_band.iloc[i]
            final_lower.iloc[i] = final_lower.iloc[i-1] if i > 0 else lower_band.iloc[i]
