        # Entry conditions (barstate.isconfirmed = True for all bars in backtesting)
        # LONG
        long_setup = bars_since_bull_sweep > 0 and bars_since_bull_sweep <= fvg_wait_bars
        long_entry = long_setup and (not wait_for_fvg or bullish_fvg_valid) and session_filter
        
        # SHORT
        short_setup = bars_since_bear_sweep > 0 and bars_since_bear_sweep <= fvg_wait_bars
        short_entry = short_setup and (not wait_for_fvg or bearish_fvg_valid) and session_filter
        
        if short_entry:
            entries.append({
                'trade_num': len(entries) + 1,
                'direction': 'short',
                'entry_bar': i,
                'entry_price': df['close'].iloc[i]
            })
            last_bear_sweep_bar = None
        
        if long_entry:
            entries.append({
                'trade_num': len(entries) + 1,
                'direction': 'long',
                'entry_bar': i,
                'entry_price': df['close'].iloc[i]
            })
            last_bull_sweep_bar = None

    return entries

