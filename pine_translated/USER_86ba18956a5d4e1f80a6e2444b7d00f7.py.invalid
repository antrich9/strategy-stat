            if bullFvgUpper != bullFvgLower:
                pct = (bullFvgUpper - bullFvgLower) / (bullFvgUpper - bullFvgLower)
                if pct > 0:
                    fvg_last_pct = pct
                    fvg.clear()
        
        elif last == False and low.iloc[i] < bearFvgLower and high.iloc[i] < bearFvgLower:
            if bearFvgUpper != bearFvgLower:
                pct = (bearFvgUpper - bearFvgLower) / (bearFvgUpper - bearFvgLower)
                if pct > 0:
                    fvg_last_pct = pct
                    fvg.clear()
        
        # Check entry conditions
