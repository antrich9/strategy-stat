import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    fvgTH = 0.5
    fvg_last_pct = np.nan
    fvg_active = False
    last = None
    
    # FVG tracking variables
    bullFvgUpper = np.nan
    bullFvgLower = np.nan
    bearFvgUpper = np.nan
    bearFvgLower = np.nan
    bullstop = np.nan
    bearstop = np.nan
    
    entries = []
    trade_num = 1
    
    # ATR(144) using Wilder's method
    high = df['high']
    low = df['low']
    close = df['close']
    
    tr = pd.concat([high - low, 
                    (high - close.shift(1)).abs(), 
                    (low - close.shift(1)).abs()], axis=1).max(axis=1)
    atr = tr.ewm(alpha=1/144, adjust=False).mean()
    
    for i in range(2, len(df)):
        bullG = low.iloc[i] > high.iloc[i-1]
        bearG = high.iloc[i] < low.iloc[i-1]
        
        current_atr = atr.iloc[i] * fvgTH if not pd.isna(atr.iloc[i]) else np.nan
        
        bull_condition = (low.iloc[i] - high.iloc[i-2]) > current_atr and \
                         low.iloc[i] > high.iloc[i-2] and \
                         close.iloc[i-1] > high.iloc[i-2] and \
                         not (bullG or (low.iloc[i-1] > high.iloc[i-2] if i-1 >= 0 else False))
        
        bear_condition = (low.iloc[i-2] - high.iloc[i]) > current_atr and \
                        high.iloc[i] < low.iloc[i-2] and \
                        close.iloc[i-1] < low.iloc[i-2] and \
                        not (bearG or (high.iloc[i-1] < low.iloc[i-2] if i-1 >= 0 else False))
        
        if bull_condition:
            bullFvgUpper = high.iloc[i-2]
            bullFvgLower = low.iloc[i]
            bullstop = low.iloc[i-2]
            fvg_active = True
            last = True
            fvg_last_pct = 0.0
            
        if bear_condition:
            bearFvgUpper = high.iloc[i]
            bearFvgLower = low.iloc[i-2]
            bearstop = high.iloc[i-2]
            fvg_active = True
            last = False
            fvg_last_pct = 0.0
            
        if bullG or bearG:
            fvg_active = False
            
        if fvg_active and fvg_last_pct > 0.01 and fvg_last_pct <= 1:
            if last == True:
                bullMidpoint = (bullFvgUpper + bullFvgLower) / 2 if not pd.isna(bullFvgUpper) and not pd.isna(bullFvgLower) else np.nan
                if not pd.isna(bullMidpoint) and low.iloc[i] < bullMidpoint and low.iloc[i-1] >= bullMidpoint:
                    entries.append({
                        'trade_num': trade_num,
                        'direction': 'long',
                        'entry_ts': int(df['time'].iloc[i]),
                        'entry_time': datetime.fromtimestamp(df['time'].iloc[i]/1000, tz=timezone.utc).isoformat(),
                        'entry_price_guess': close.iloc[i],
                        'exit_ts': 0,
                        'exit_time': '',
                        'exit_price_guess': 0.0,
                        'raw_price_a': close.iloc[i],
                        'raw_price_b': close.iloc[i]
                    })
                    trade_num += 1
                    fvg_active = False
                    
            elif last == False:
                bearMidpoint = (bearFvgUpper + bearFvgLower) / 2 if not pd.isna(bearFvgUpper) and not pd.isna(bearFvgLower) else np.nan
                if not pd.isna(bearMidpoint) and high.iloc[i] > bearMidpoint and high.iloc[i-1] <= bearMidpoint:
                    entries.append({
                        'trade_num': trade_num,
                        'direction': 'short',
                        'entry_ts': int(df['time'].iloc[i]),
                        'entry_time': datetime.fromtimestamp(df['time'].iloc[i]/1000, tz=timezone.utc).isoformat(),
                        'entry_price_guess': close.iloc[i],
                        'exit_ts': 0,
                        'exit_time': '',
                        'exit_price_guess': 0.0,
                        'raw_price_a': close.iloc[i],
                        'raw_price_b': close.iloc[i]
                    })
                    trade_num += 1
                    fvg_active = False
        
        # Update fvg_last_pct based on price action in the FVG zone
        if fvg_active and not pd.isna(bullFvgUpper):
            if last == True:
                upper = bullFvgUpper
                lower = bullFvgLower
                if high.iloc[i] > upper and low.iloc[i] < upper:
                    if close.iloc[i] > lower:
                        new_lower = min(close.iloc[i], lower)
                        fvg_last_pct = (upper - new_lower) / (upper - lower)
                    else:
                        fvg_last_pct = 1.0
                        fvg_active = False
                        
            elif last == False:
                upper = bearFvgUpper
                lower = bearFvgLower
                if high.iloc[i] > upper and low.iloc[i] < upper:
                    if close.iloc[i] < upper:
                        new_upper = max(close.iloc[i], upper)
                        fvg_last_pct = (new_upper - lower) / (upper - lower)
                    else:
                        fvg_last_pct = 1.0
                        fvg_active = False
    
    return entries

I'm calculating the new midpoint based on whether we're in a bullish or bearish FVG. For bullish setups, if price enters from above, I update the lower boundary and recalculate the percentage. For bearish setups, I adjust the upper boundary similarly. When price crosses the opposite extreme, the FVG becomes inactive. The percentage thresholds of 0.01 and 1.0 represent the minimum and maximum bounds for valid FVGs. When `last` is true, I check for a bullish crossover at the bull midpoint using `ta.crossunder(low, bullMidpoint)`, which translates to checking if the previous low was above or equal to the midpoint while the current low drops below it. For bearish scenarios where `last` is false, I need a bearish crossover at the bear midpoint with `ta.crossover(high, bearMidpoint)`, meaning the previous high should be below or equal to the midpoint while the current high rises above it.

