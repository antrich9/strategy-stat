def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based.
    
    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    import pandas as pd
    import numpy as np
    from datetime import datetime, timezone
    
    if len(df) < 20:
        return []
    
    # Wilde's RSI implementation
    def wilders_rsi(series, length):
        delta = series.diff()
        gain = delta.where(delta > 0, 0.0)
        loss = (-delta).where(delta < 0, 0.0)
        avg_gain = gain.ewm(alpha=1.0/length, adjust=False).mean()
        avg_loss = loss.ewm(alpha=1.0/length, adjust=False).mean()
        rs = avg_gain / avg_loss.replace(0, np.nan)
        return 100 - (100 / (1 + rs))
    
    # Wilde's ATR implementation
    def wilders_atr(high, low, close, length):
        tr1 = high - low
        tr2 = abs(high - close.shift(1))
        tr3 = abs(low - close.shift(1))
        true_range = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
        return true_range.ewm(alpha=1.0/length, adjust=False).mean()
    
    # Validate required columns exist
    required_cols = ['time', 'open', 'high', 'low', 'close', 'volume']
    for col in required_cols:
        if col not in df.columns:
            return []
    
    # Calculate previous day high and low from daily data
    df_copy = df.copy()
    df_copy['date'] = pd.to_datetime(df_copy['time'], unit='s', utc=True).dt.date
    daily_agg = df_copy.groupby('date').agg({'high': 'max', 'low': 'min'})
    daily_agg['prev_day_high'] = daily_agg['high'].shift(1)
    daily_agg['prev_day_low'] = daily_agg['low'].shift(1)
    df_copy = df_copy.merge(daily_agg[['prev_day_high', 'prev_day_low']], on='date', how='left')
    
    # Calculate Wilder's RSI and ATR with minimum 20 periods
    rsi_series = wilders_rsi(df_copy['close'], 20) if len(df_copy) >= 20 else pd.Series([np.nan] * len(df_copy))
    atr_series = wilders_atr(df_copy['high'], df_copy['low'], df_copy['close'], 14) if len(df_copy) >= 14 else pd.Series([np.nan] * len(df_copy))
    
    # Flat RSI and ATR into 1D arrays
    rsi_flat = rsi_series.values.flatten()
    atr_flat = atr_series.values.flatten()
    
    # Check for NaN values in RSI and ATR
    rsi_nan = np.isnan(rsi_flat)
    atr_nan = np.isnan(atr_flat)
    
    # London time window filtering
    london_hours = [(7, 45), (8, 0), (8, 30), (8, 45), (8, 59),
                    (14, 45), (15, 0), (15, 30), (15, 45), (15, 59)]
    timestamps = df_copy['time'].values
    
    # Entry conditions
    long_condition = ((df_copy['close'] > df_copy['prev_day_high'].values) & 
                     (rsi_flat > 50) & 
                     (atr_flat < df_copy['close'].values * 0.02) &
                     (~rsi_nan) & 
                     (~atr_nan))
    
    short_condition = ((df_copy['close'] < df_copy['prev_day_low'].values) & 
                      (rsi_flat < 50) & 
                      (atr_flat > df_copy['close'].values * 0.02) &
                      (~rsi_nan) & 
                      (~atr_nan))
    
    # Filter entries by London time window
    london_mask = np.zeros(len(df_copy), dtype=bool)
    for i in range(len(df_copy)):
        ts = timestamps[i]
        dt = datetime.utcfromtimestamp(ts)
        if (dt.hour, dt.minute) in london_hours:
            london_mask[i] = True
    
    long_entries = long_condition & london_mask
    short_entries = short_condition & london_mask
    
    entries = []
    trade_num = 1
    
    # Process long entries
    for i in range(len(df_copy)):
        if long_entries[i]:
            ts = int(df_copy['time'].iloc[i])
            dt = datetime.utcfromtimestamp(ts)
            entry = {
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': ts,
                'entry_time': dt.isoformat() + 'Z',
                'entry_price_guess': float(df_copy['close'].iloc[i]),
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': float(df_copy['close'].iloc[i]),
                'raw_price_b': float(df_copy['close'].iloc[i])
            }
            entries.append(entry)
            trade_num += 1
    
    # Process short entries
    for i in range(len(df_copy)):
        if short_entries[i]:
            ts = int(df_copy['time'].iloc[i])
            dt = datetime.utcfromtimestamp(ts)
            entry = {
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': ts,
                'entry_time': dt.isoformat() + 'Z',
                'entry_price_guess': float(df_copy['close'].iloc[i]),
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': float(df_copy['close'].iloc[i]),
                'raw_price_b': float(df_copy['close'].iloc[i])
            }
            entries.append(entry)
            trade_num += 1
    
    return entries

