import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    atrLength = 14
    atrMultiplier = 1.5
    takeProfitRatio = 1.5
    tradeDirection = "Both"
    rmaLength = 14
    input_lookback = 20
    input_retSince = 2
    input_retValid = 2
    input_breakout = True
    input_retest = True
    input_repType = 'On'
    
    bb = input_lookback
    
    # Calculate ATR (Wilder RSI method)
    high = df['high']
    low = df['low']
    close = df['close']
    
    tr1 = high - low
    tr2 = np.abs(high - close.shift(1))
    tr3 = np.abs(low - close.shift(1))
    true_range = np.maximum(tr1, np.maximum(tr2, tr3))
    
    atr = np.zeros(len(df))
    atr[atrLength - 1] = true_range.iloc[:atrLength].mean()
    for i in range(atrLength, len(df)):
        atr[i] = (atr[i - 1] * (atrLength - 1) + true_range.iloc[i]) / atrLength
    atr_series = pd.Series(atr, index=df.index)
    
    # Calculate pivot points
    pl = pd.Series(np.nan, index=df.index)  # pivot low
    ph = pd.Series(np.nan, index=df.index)  # pivot high
    
    for i in range(bb, len(df) - bb):
        if all(low.iloc[i - bb:i + bb + 1] <= low.iloc[i]):
            pl.iloc[i] = low.iloc[i]
        if all(high.iloc[i - bb:i + bb + 1] >= high.iloc[i]):
            ph.iloc[i] = high.iloc[i]
    
    pl = pl.fillna(method='ffill')
    ph = ph.fillna(method='ffill')
    
    # RMA calculation (Wilder smoothing)
    rma = close.ewm(alpha=1/rmaLength, adjust=False).mean()
    
    # Box levels (simplified approach)
    sTop = pd.Series(np.nan, index=df.index)
    sBot = pd.Series(np.nan, index=df.index)
    rTop = pd.Series(np.nan, index=df.index)
    rBot = pd.Series(np.nan, index=df.index)
    
    # Track active boxes
    sBox_top = pd.Series(np.nan, index=df.index)
    sBox_bot = pd.Series(np.nan, index=df.index)
    rBox_top = pd.Series(np.nan, index=df.index)
    rBox_bot = pd.Series(np.nan, index=df.index)
    
    # Detect box changes and track support/resistance levels
    sBreak = pd.Series(False, index=df.index)
    rBreak = pd.Series(False, index=df.index)
    
    cu = pd.Series(False, index=df.index)
    co = pd.Series(False, index=df.index)
    
    # Iterate through each bar to identify breakouts and retests
    for i in range(len(df)):
        # Check for pivot point changes and update boxes accordingly
        if i > 0 and not pd.isna(pl.iloc[i]) and pl.iloc[i] != pl.iloc[i-1]:
            if i > bb:
                sBreak.iloc[i] = True
                sBox_bot.iloc[i] = pl.iloc[i]
                
        if i > 0 and not pd.isna(ph.iloc[i]) and ph.iloc[i] != ph.iloc[i-1]:
            if i > bb:
                rBreak.iloc[i] = True
                rBox_top.iloc[i] = ph.iloc[i]
        
        # Detect crossovers and crossunders for entries
        if i > 0:
            if not pd.isna(sBox_bot.iloc[i-1]):
                if close.iloc[i] < sBox_bot.iloc[i-1] and close.iloc[i-1] >= sBox_bot.iloc[i-1]:
                    cu.iloc[i] = True
            if not pd.isna(rBox_top.iloc[i-1]):
                if close.iloc[i] > rBox_top.iloc[i-1] and close.iloc[i-1] <= rBox_top.iloc[i-1]:
                    co.iloc[i] = True

