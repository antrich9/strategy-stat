import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    atrLength = 14
    atrMultiplier = 1.5
    takeProfitRatio = 1.5
    tradeDirection = "Both"
    rmaLength = 14
    input_lookback = 20
    input_retSince = 2
    input_retValid = 2
    input_breakout = True
    input_retest = True
    input_repType = 'On'
    
    bb = input_lookback
    
    high = df['high']
    low = df['low']
    close = df['close']
    time_col = df['time']
    
    # ATR calculation (Wilder method)
    tr1 = high - low
    tr2 = np.abs(high - close.shift(1))
    tr3 = np.abs(low - close.shift(1))
    true_range = np.maximum(tr1, np.maximum(tr2, tr3))
    
    atr = np.zeros(len(df))
    atr[atrLength - 1] = true_range.iloc[:atrLength].mean()
    for i in range(atrLength, len(df)):
        atr[i] = (atr[i - 1] * (atrLength - 1) + true_range.iloc[i]) / atrLength
    atr_series = pd.Series(atr, index=df.index)
    
    # Pivot detection
    pl = pd.Series(np.nan, index=df.index)
    ph = pd.Series(np.nan, index=df.index)
    
    for i in range(bb, len(df) - bb):
        if low.iloc[i] <= low.iloc[i - bb:i + bb + 1].min():
            pl.iloc[i] = low.iloc[i]
        if high.iloc[i] >= high.iloc[i - bb:i + bb + 1].max():
            ph.iloc[i] = high.iloc[i]
    
    pl = pl.ffill()
    ph = ph.ffill()
    
    # Calculate support and resistance levels
    sBot = low.rolling(bb + 1).min().shift(1)
    sTop = low.rolling(bb + 1).max().shift(1)
    rBot = high.rolling(bb + 1).min().shift(1)
    rTop = high.rolling(bb + 1).max().shift(1)
    
    sBreak = pd.Series(False, index=df.index)
    rBreak = pd.Series(False, index=df.index)
    cu = pd.Series(False, index=df.index)
    co = pd.Series(False, index=df.index)
    
    # Track box boundaries
    sBox_bot = pd.Series(np.nan, index=df.index)
    sBox_top = pd.Series(np.nan, index=df.index)
    rBox_bot = pd.Series(np.nan, index=df.index)
    rBox_top = pd.Series(np.nan, index=df.index)
    
    for i in range(bb + 1, len(df)):
        if not pd.isna(pl.iloc[i]) and pl.iloc[i] != pl.iloc[i-1]:
            sBox_bot.iloc[i] = pl.iloc[i]
            sBox_top.iloc[i] = low.iloc[i-bb:i+1].max() if i >= bb else low.iloc[:i+1].max()
        elif i > 0 and not pd.isna(sBox_bot.iloc[i-1]):
            sBox_bot.iloc[i] = sBox_bot.iloc[i-1]
            sBox_top.iloc[i] = sBox_top.iloc[i-1]
        
        if not pd.isna(ph.iloc[i]) and ph.iloc[i] != ph.iloc[i-1]:
            rBox_top.iloc[i] = ph.iloc[i]
            rBox_bot.iloc[i] = high.iloc[i-bb:i+1].min() if i >= bb else high.iloc[:i+1].min()
        elif i > 0 and not pd.isna(rBox_bot.iloc[i-1]):
            rBox_bot.iloc[i] = rBox_bot.iloc[i-1]
            rBox_top.iloc[i] = rBox_top.iloc[i-1]
    
    # RMA calculation
    rma = close.ewm(alpha=1/rmaLength, adjust=False).mean()
    
    # Breakout detection
    for i in range(bb + 1, len(df)):
        if input_repType == 'On':
            cu.iloc[i] = close.iloc[i] < sBox_bot.iloc[i] and close.iloc[i-1] >= sBox_bot.iloc[i]
            co.iloc[i] = close.iloc[i] > rBox_top.iloc[i] and close.iloc[i-1] <= rBox_top.iloc[i]
        elif input_repType == 'Off: High & Low':
            cu.iloc[i] = low.iloc[i] < sBox_bot.iloc[i] and low.iloc[i-1] >= sBox_bot.iloc[i]
            co.iloc[i] = high.iloc[i] > rBox_top.iloc[i] and high.iloc[i-1] <= rBox_top.iloc[i]
        else:  # Candle Confirmation
            cu.iloc[i] = close.iloc[i] < sBox_bot.iloc[i] and close.iloc[i-1] >= sBox_bot.iloc[i] and True
            co.iloc[i] = close.iloc[i] > rBox_top.iloc[i] and close.iloc[i-1] <= rBox_top.iloc[i] and True
        
        if cu.iloc[i] and pd.isna(sBreak.iloc[i]):
            sBreak.iloc[i] = True
        
        if co.iloc[i] and pd.isna(rBreak.iloc[i]):
            rBreak.iloc[i] = True
        
        if pd.notna(pl.iloc[i]) and pl.iloc[i] != pl.iloc[i-1]:
            if pd.isna(sBreak.iloc[i]):
                sBreak.iloc[i] = False
            else:
                sBreak.iloc[i] = np.nan
        
        if pd.notna(ph.iloc[i]) and ph.iloc[i] != ph.iloc[i-1]:
            if pd.isna(rBreak.iloc[i]):
                rBreak.iloc[i] = False
            else:
                rBreak.iloc[i] = np.nan
    
    # Retest conditions for support breakouts
    s1 = (~sBreak.isna()) & (sBreak) & (high >= sTop) & (close <= sBot)
    s2 = (~sBreak.isna()) & (sBreak) & (high >= sTop) & (close >= sBot) & (close <= sTop)
    s3 = (~sBreak.isna()) & (sBreak) & (high >= sBot) & (high <= sTop)
    s4 = (~sBreak.isna()) & (sBreak) & (high >= sBot) & (high <= sTop) & (close < sBot)
    
    # Retest conditions for resistance breakouts
    r1 = (~rBreak.isna()) & (rBreak) & (low <= rBot) & (close >= rTop)
    r2 = (~rBreak.isna()) & (rBreak) & (low <= rBot) & (close <= rTop) & (close >= rBot)
    r3 = (~rBreak.isna()) & (rBreak) & (low <= rTop) & (low >= rBot)
    r4 = (~rBreak.isna()) & (rBreak) & (low <= rTop) & (low >= rBot) & (close > rTop)
    
    sRetValid = pd.Series(False, index=df.index)
    rRetValid = pd.Series(False, index=df.index)
    
    sRetOccurred = False
    rRetOccurred = False
    
    for i in range(bb + 1, len(df)):
        sRetActive = s1.iloc[i] or s2.iloc[i] or s3.iloc[i] or s4.iloc[i]
        rRetActive = r1.iloc[i] or r2.iloc[i] or r3.iloc[i] or r4.iloc[i]
        
        sRetEvent = sRetActive and not sRetActive
        rRetEvent = rRetActive and not rRetActive

I'm computing the breakout signals by checking if price crosses below the support box or above the resistance box, with repainting logic to handle the different confirmation modes. When a breakout occurs, I track whether we've already broken support or resistance, resetting those flags when new pivots form. Then I'm evaluating the retest conditions that follow breakouts—both for support breaks (checking if price respects the former support as resistance) and resistance breaks (checking if price respects the former resistance as support). I need to check for both long and short entries since the default trade direction is "Both". The function should emit long entries on rRetValid events and short entries on sRetValid events. I'm going to implement this logic directly in the function rather than refactoring further.

Here's the implementation approach: calculate ATR and RMA, detect pivots and boxes, identify breakouts, then evaluate retests using multiple conditions. For each bar, I'll check if the retest criteria are met for both directions and generate the appropriate entries.

import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    atrLength = 14
    atrMultiplier = 1.5
    takeProfitRatio = 1.5
    tradeDirection = "Both"
    rmaLength = 14
    input_lookback = 20
    input_retSince = 2
    input_retValid = 2
    input_breakout = True
    input_retest = True
    input_repType = 'On'
    
    bb = input_lookback
    
    high = df['high']
    low = df['low']
    close = df['close']
    time_col = df['time']
    
    # ATR calculation (Wilder method)
    tr1 = high - low
    tr2 = np.abs(high - close.shift(1))
    tr3 = np.abs(low - close.shift(1))
    true_range = np.maximum(tr1, np.maximum(tr2, tr3))
    
    atr = np.zeros(len(df))
    atr[atrLength - 1] = true_range.iloc[:atrLength].mean()
    for i in range(atrLength, len(df)):
        atr[i] = (atr[i - 1] * (atrLength - 1) + true_range.iloc[i]) / atrLength
    atr_series = pd.Series(atr, index=df.index)
    
    # Pivot detection
    pl = pd.Series(np.nan, index=df.index)
    ph = pd.Series(np.nan, index=df.index)
    
    for i in range(bb, len(df) - bb):
        if low.iloc[i] <= low.iloc[i - bb:i + bb + 1].min():
            pl.iloc[i] = low.iloc[i]
        if high.iloc[i] >= high.iloc[i - bb:i + bb + 1].max():
            ph.iloc[i] = high.iloc[i]
    
    pl = pl.ffill()
    ph = ph.ffill()
    
    # Calculate support and resistance levels
    sBot = low.rolling(bb + 1).min().shift(1)
    sTop = low.rolling(bb + 1).max().shift(1)
    rBot = high.rolling(bb + 1).min().shift(1)
    rTop = high.rolling(bb + 1).max().shift(1)
    
    sBreak = pd.Series(False, index=df.index)
    rBreak = pd.Series(False, index=df.index)
    cu = pd.Series(False, index=df.index)
    co = pd.Series(False, index=df.index)
    
    # Track box boundaries
    sBox_bot = pd.Series(np.nan, index=df.index)
    sBox_top = pd.Series(np.nan, index=df.index)
    rBox_bot = pd.Series(np.nan, index=df.index)
    rBox_top = pd.Series(np.nan, index=df.index)
    
    for i in range(bb + 1, len(df)):
        if not pd.isna(pl.iloc[i]) and pl.iloc[i] != pl.iloc[i-1]:
            sBox_bot.iloc[i] = pl.iloc[i]
            sBox_top.iloc[i] = low.iloc[max(0, i-bb):i+1].max()
        elif i > 0 and not pd.isna(sBox_bot.iloc[i-1]):
            sBox_bot.iloc[i] = sBox_bot.iloc[i-1]
            sBox_top.iloc[i] = sBox_top.iloc[i-1]
        
        if not pd.isna(ph.iloc[i]) and ph.iloc[i] != ph.iloc[i-1]:
            rBox_top.iloc[i] = ph.iloc[i]
            rBox_bot.iloc[i] = high.iloc[max(0, i-bb):i+1].min()
        elif i > 0 and not pd.isna(rBox_bot.iloc[i-1]):
            rBox_bot.iloc[i] = rBox_bot.iloc[i-1]
            rBox_top.iloc[i] = rBox_top.iloc[i-1]
    
    # RMA calculation
    rma = close.ewm(alpha=1/rmaLength, adjust=False).mean()
    
    # Breakout detection
    for i in range(bb + 1, len(df)):
        if input_repType == 'On':
            cu.iloc[i] = close.iloc[i] < sBox_bot.iloc[i] and close.iloc[i-1] >= sBox_bot.iloc[i]
            co.iloc[i] = close.iloc[i] > rBox_top.iloc[i] and close.iloc[i-1] <= rBox_top.iloc[i]
        elif input_repType == 'Off: High & Low':
            cu.iloc[i] = low.iloc[i] < sBox_bot.iloc[i] and low.iloc[i-1] >= sBox_bot.iloc[i]
            co.iloc[i] = high.iloc[i] > rBox_top.iloc[i] and high.iloc[i-1] <= rBox_top.iloc[i]
        else:  # Candle Confirmation
            cu.iloc[i] = close.iloc[i] < sBox_bot.iloc[i] and close.iloc[i-1] >= sBox_bot.iloc[i]
            co.iloc[i] = close.iloc[i] > rBox_top.iloc[i] and close.iloc[i-1] <= rBox_top.iloc[i]
        
        if cu.iloc[i] and pd.isna(sBreak.iloc[i]):
            sBreak.iloc[i] = True
        
        if co.iloc[i] and pd.isna(rBreak.iloc[i]):
            rBreak.iloc[i] = True
        
        if pd.notna(pl.iloc[i]) and pl.iloc[i] != pl.iloc[i-1]:
            if pd.isna(sBreak.iloc[i]):
                sBreak.iloc[i] = False
            else:
                sBreak.iloc[i] = np.nan
        
        if pd.notna(ph.iloc[i]) and ph.iloc[i] != ph.iloc[i-1]:
            if pd.isna(rBreak.iloc[i]):
                rBreak.iloc[i] = False
            else:
                rBreak.iloc[i] = np.nan
    
    # Retest conditions for support breakouts
