import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    bb = 20  # lookback range
    input_retSince = 2  # bars since breakout
    input_retValid = 2  # retest detection limiter
    input_breakout = True  # enable breakouts
    input_retest = True  # enable retests
    trade_direction = 'Both'  # 'Long', 'Short', or 'Both'
    
    # State variables
    sBreak = pd.Series([False] * len(df))
    rBreak = pd.Series([False] * len(df))
    retOccurred_s = pd.Series([False] * len(df))
    retOccurred_r = pd.Series([False] * len(df))
    
    # Calculate pivot points and support/resistance levels
    pl = fixnan(ta.pivotlow(df['low'], bb, bb))
    ph = fixnan(ta.pivothigh(df['high'], bb, bb))
    
    sTop = pl - bb  # support level adjusted by lookback
    sBot = pl + bb  # support level adjusted by lookback
    rTop = ph - bb  # resistance level adjusted by lookback
    rBot = ph + bb  # resistance level adjusted by lookback
    
    # Detect breakouts and apply retest logic
    for i in range(len(df)):
        # Update breakout flags
        if df['close'].iloc[i] > rTop.iloc[i] and not rBreak.iloc[i-1] if i > 0 else True:
            rBreak.iloc[i] = True
        
        if df['close'].iloc[i] < sBot.iloc[i] and not sBreak.iloc[i-1] if i > 0 else True:
            sBreak.iloc[i] = True
        
        # Retest validation for support
        if sBreak.iloc[i] and not retOccurred_s.iloc[i]:
            if df['low'].iloc[i] <= sBot.iloc[i] and df['close'].iloc[i] >= sTop.iloc[i]:
                retOccurred_s.iloc[i] = True
        
        # Retest validation for resistance
        if rBreak.iloc[i] and not retOccurred_r.iloc[i]:
            if df['high'].iloc[i] >= rTop.iloc[i] and df['close'].iloc[i] <= rBot.iloc[i]:
                retOccurred_r.iloc[i] = True

This structure handles the breakout detection, state tracking, and retest validation across iterations. The state variables track whether breakouts have occurred and whether retests have been validated. - s4 = retestCondition(sBreak, high >= sBot and high <= sTop and close < sBot)

