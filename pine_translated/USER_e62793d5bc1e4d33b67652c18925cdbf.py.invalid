import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    bb = 20
    input_retSince = 2
    input_retValid = 2
    input_breakout = True
    input_retest = True
    trade_direction = 'Both'
    
    close = df['close']
    high = df['high']
    low = df['low']
    
    pl = _pivot_low(low, bb)
    ph = _pivot_high(high, bb)
    
    pl_change = (pl != pl.shift(1)) & pl.notna()
    ph_change = (ph != ph.shift(1)) & ph.notna()
    
    pl_filled = pl.ffill().fillna(0)
    ph_filled = ph.ffill().fillna(0)
    
    s_yLoc = np.where(low.shift(bb+1) > low.shift(bb-1), low.shift(bb-1), low.shift(bb+1))
    r_yLoc = np.where(high.shift(bb+1) > high.shift(bb-1), high.shift(bb+1), high.shift(bb-1))
    
    sBot = pl_filled
    sTop = s_yLoc
    rTop = ph_filled
    rBot = r_yLoc
    
    sBreak = pd.Series([False] * len(df))
    rBreak = pd.Series([False] * len(df))
    
    co = pd.Series([False] * len(df))
    cu = pd.Series([False] * len(df))
    
    sRetValid = pd.Series([0] * len(df), dtype=int)
    rRetValid = pd.Series([0] * len(df), dtype=int)
    
    retOccurred_s = pd.Series([False] * len(df))
    retOccurred_r = pd.Series([False] * len(df))
    
    s_labels = []
    r_labels = []
    s_ret_values = []
    r_ret_values = []
    
    for i in range(bb, len(df)):
        if pl_change.iloc[i]:
            if not sBreak.iloc[i-1] if i > bb else True:
                pass
            
            if sBreak.iloc[i-1] if i > bb else False:
                sBreak.iloc[i] = False
            else:
                sBreak.iloc[i] = False
        
        if ph_change.iloc[i]:
            if not rBreak.iloc[i-1] if i > bb else True:
                pass
            
            if rBreak.iloc[i-1] if i > bb else False:
                rBreak.iloc[i] = False
            else:
                rBreak.iloc[i] = False
        
        sBot_val = sBot.iloc[i] if sBot.iloc[i] != 0 else np.nan
        sTop_val = sTop.iloc[i] if isinstance(sTop.iloc[i], (int, float)) and not np.isnan(sTop.iloc[i]) else np.nan
        rTop_val = rTop.iloc[i] if rTop.iloc[i] != 0 else np.nan
        rBot_val = rBot.iloc[i] if isinstance(rBot.iloc[i], (int, float)) and not np.isnan(rBot.iloc[i]) else np.nan
        
        co_val = close.iloc[i] > rTop_val if rTop_val and not np.isnan(rTop_val) else False
        cu_val = close.iloc[i] < sBot_val if sBot_val and not np.isnan(sBot_val) else False
        
        co_val = co_val and (co.iloc[i-1] if i > bb else False) == False
        cu_val = cu_val and (cu.iloc[i-1] if i > bb else False) == False
        
        co.iloc[i] = co_val
        cu.iloc[i] = cu_val
        
        if co_val:
            rBreak.iloc[i] = True
        
        if cu_val:
            sBreak.iloc[i] = True
        
        if sBreak.iloc[i]:
            s1 = bars_since(pl_change, i) > input_retSince and high.iloc[i] >= sTop_val and close.iloc[i] <= sBot_val
            s2 = bars_since(pl_change, i) > input_retSince and high.iloc[i] >= sTop_val and close.iloc[i] >= sBot_val and close.iloc[i] <= sTop_val
            s3 = bars_since(pl_change, i) > input_retSince and high.iloc[i] >= sBot_val and high.iloc[i] <= sTop_val
            s4 = bars_since(pl_change, i) > input_retSince and high.iloc[i] >= sBot_val and high.iloc[i] <= sTop_val and close.iloc[i] < sBot_val
            
            if s1 or s2 or s3 or s4:
                s_labels.append(i)
                s_ret_values.append(sBot_val)
        
        if rBreak.iloc[i]:
            r1 = bars_since(ph_change, i) > input_retSince and low.iloc[i] <= rBot_val and close.iloc[i]