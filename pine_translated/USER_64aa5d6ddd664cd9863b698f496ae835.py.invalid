import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    open_col = df['open']
    high_col = df['high']
    low_col = df['low']
    close_col = df['close']
    volume_col = df['volume']
    time_col = df['time']
    
    n = len(df)
    entries = []
    trade_num = 1
    
    def isUp(idx):
        return close_col.iloc[idx] > open_col.iloc[idx]
    
    def isDown(idx):
        return close_col.iloc[idx] < open_col.iloc[idx]
    
    def isObUp(idx):
        return (isDown(idx - 1) and 
                isUp(idx) and 
                close_col.iloc[idx] > high_col.iloc[idx - 1])
    
    def isObDown(idx):
        return (isUp(idx - 1) and 
                isDown(idx) and 
                close_col.iloc[idx] < low_col.iloc[idx - 1])
    
    def isFvgUp(idx):
        return low_col.iloc[idx] > high_col.iloc[idx - 2]
    
    def isFvgDown(idx):
        return high_col.iloc[idx] < low_col.iloc[idx - 2]
    
    obUp = isObUp(1)
    obDown = isObDown(1)
    fvgUp = isFvgUp(0)
    fvgDown = isFvgDown(0)
    
    sma9_vol = volume_col.rolling(window=9).mean()
    sma54 = close_col.rolling(window=54).mean()
    
    high_close_abs = np.abs(close_col - close_col.shift(1))
    hl = high_col - low_col
    lc = np.abs(close_col - low_col)
    hc = np.abs(high_col - close_col)
    tr = np.maximum(hl, np.maximum(hc, lc))
    atr = tr.ewm(span=20, adjust=False).mean()
    
    bullFVG = (
        (low_col > high_col.shift(2)) &
        (volume_col > sma9_vol * 1.5) &
        ((low_col - high_col.shift(2)) > (atr / 1.5)) &
        (sma54 > sma54.shift(1))
    )
    
    bearFVG = (
        (high_col < low_col.shift(2)) &
        (volume_col > sma9_vol * 1.5) &
        ((low_col.shift(2) - high_col) > (atr / 1.5)) &
        (sma54 < sma54.shift(1))
    )
    
    london_start_morning = int(datetime(2020, 1, 1, 7, 45, tzinfo=timezone.utc).timestamp() * 1000)
    london_end_morning = int(datetime(2020, 1, 1, 9, 45, tzinfo=timezone.utc).timestamp() * 1000)
    london_start_afternoon = int(datetime(2020, 1, 1, 14, 45, tzinfo=timezone.utc).timestamp() * 1000)
    london_end_afternoon = int(datetime(2020, 1, 1, 16, 45, tzinfo=timezone.utc).timestamp() * 1000)
    
    def in_trading_window(ts):
        return (
            (london_start_morning <= ts < london_end_morning) or
            (london_start_afternoon <= ts < london_end_afternoon)
        )
    
    for i in range(2, n):
        if pd.isna(obUp.iloc[i]) or pd.isna(obDown.iloc[i]) or pd.isna(fvgUp.iloc[i]) or pd.isna(fvgDown.iloc[i]):
            continue
        if pd.isna(bullFVG.iloc[i]) or pd.isna(bearFVG.iloc[i]) or pd.isna(atr.iloc[i]) or pd.isna(sma54.iloc[i]):
            continue
        
        if in_trading_window(time_col.iloc[i]):
            if obUp.iloc[i] and fvgUp.iloc[i] and bullFVG.iloc[i]:
                ts = int(time_col.iloc[i])
                entry = {
                    'trade_num': trade_num,
                    'direction': 'long',
                    'entry_ts': ts,
                    'entry_time': datetime.fromtimestamp(ts / 1000, tz=timezone.utc).isoformat(),
                    'entry_price_guess': float(close_col.iloc[i]),
                    'exit_ts': 0,
                    'exit_time': '',
                    'exit_price_guess': 0.0,
                    'raw_price_a': float(close_col.iloc[i]),
                    'raw_price_b': float(close_col.iloc[i])
                }
                entries.append(entry)
                trade_num += 1
            elif obDown.iloc[i] and fvgDown.iloc[i] and bearFVG.iloc[i]:
                ts = int(time_col.iloc[i])
                entry = {
                    'trade_num': trade_num,
                    'direction': 'short',
                    'entry_ts': ts,
                    'entry_time': datetime.fromtimestamp(ts / 1000, tz=timezone.utc).isoformat(),
                    'entry_price_guess': float(close_col.iloc[i]),
                    'exit_ts': 0,
                    'exit_time': '',
                    'exit_price_guess': 0.0,
                    'raw_price_a': float(close_col.iloc[i]),
                    'raw_price_b': float(close_col.iloc[i])
                }
                entries.append(entry)
                trade_num += 1
    
    return entries
