import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    
    # Default parameters from Pine Script
    liq_len = 7
    liq_mar = 10 / 6.9
    fvg_wait_bars = 10
    fvg_min_ticks = 3
    atr_length = 14
    
    # Calculate ATR using Wilder's method
    high = df['high']
    low = df['low']
    close = df['close']
    
    # True Range calculation
    tr1 = high - low
    tr2 = abs(high - close.shift(1))
    tr3 = abs(low - close.shift(1))
    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
    
    # Wilder ATR
    atr = tr.ewm(alpha=1/atr_length, adjust=False).mean()
    
    # Tolerance for liquidity zones
    tolerance = atr / liq_mar
    
    # Detect pivots
    pivot_high = df['high'].rolling(window=liq_len*2+1, center=True).max()
    pivot_low = df['low'].rolling(window=liq_len*2+1, center=True).min()
    pivot_high = pivot_high.where(df['high'] == pivot_high)
    pivot_low = pivot_low.where(df['low'] == pivot_low)
    
    # FVG detection
    bullish_fvg = (df['low'] > df['high'].shift(2)) & (df['high'] < df['low'].shift(2))
    bearish_fvg = (df['high'] < df['low'].shift(2)) & (df['low'] > df['high'].shift(2))
    
    # Calculate FVG size
    bullish_fvg_size = bullish_fvg * (df['low'] - df['high'].shift(2))
    bearish_fvg_size = bearish_fvg * (df['low'].shift(2) - df['high'])
    
    # Assume a min tick size (can be adjusted based on asset)
    min_tick = 0.01
    min_fvg_size = fvg_min_ticks * min_tick
    
    bullish_fvg_valid = bullish_fvg & (bullish_fvg_size >= min_fvg_size)
    bearish_fvg_valid = bearish_fvg & (bearish_fvg_size >= min_fvg_size)
    
    # Initialize tracking variables
    last_buyside_breach_bar = None
    last_buyside_breach_price = None
    last_sellside_breach_bar = None
    last_sellside_breach_price = None
    
    entries = []
    trade_num = 0
    
    # Iterate through bars
    for i in range(len(df)):
        current_high = high.iloc[i]
        current_low = low.iloc[i]
        current_close = close.iloc[i]
        
        # Check for buyside breaches (price breaks above liquidity zone)
        if last_buyside_breach_price is not None:
            if current_high > last_buyside_breach_price + tolerance.iloc[i]:
                last_buyside_breach_bar = i
                last_buyside_breach_price = last_buyside_breach_price
        
        # Check for sellside breaches (price breaks below liquidity zone)
        if last_sellside_breach_price is not None:
            if current_low < last_sellside_breach_price - tolerance.iloc[i]:
                last_sellside_breach_bar = i
                last_sellside_breach_price = last_sellside_breach_price
        
        # Generate entries based on FVG and breach conditions
        if bullish_fvg_valid.iloc[i] and last_sellside_breach_bar is not None:
            if i - last_sellside_breach_bar <= fvg_wait_bars:
                trade_num += 1
                entries.append({
                    'trade_num': trade_num,
                    'direction': 'long',
                    'entry_ts': df['time'].iloc[i],
                    'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                    'entry_price_guess': current_close,
                    'exit_ts': 0,
                    'exit_time': '',
                    'exit_price_guess': 0.0,
                    'raw_price_a': current_close,
                    'raw_price_b': current_close
                })
                last_sellside_breach_bar = None
        
        if bearish_fvg_valid.iloc[i] and last_buyside_breach_bar is not None:
            if i - last_buyside_breach_bar <= fvg_wait_bars:
                trade_num += 1
                entries.append({
                    'trade_num': trade_num,
                    'direction': 'short',
                    'entry_ts': df['time'].iloc[i],
                    'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                    'entry_price_guess': current_close,
                    'exit_ts': 0,
                    'exit_time': '',
                    'exit_price_guess': 0.0,
                    'raw_price_a': current_close,
                    'raw_price_b': current_close
                })
                last_buyside_breach_bar = None
    
    return entries

