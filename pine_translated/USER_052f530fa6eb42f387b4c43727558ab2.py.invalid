import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    df = df.copy()
    
    # Convert to datetime and extract date for grouping
    df['datetime'] = pd.to_datetime(df['time'], unit='s', utc=True)
    df['date'] = df['datetime'].dt.date
    
    # Aggregate daily OHLC data
    daily_agg = df.groupby('date').agg(
        day_open=('open', 'first'),
        day_high=('high', 'max'),
        day_low=('low', 'min'),
        day_close=('close', 'last')
    ).reset_index()
    
    # Compute previous day's values using shift
    daily_agg['prevClose'] = daily_agg['day_close'].shift(1)
    daily_agg['prevHigh'] = daily_agg['day_high'].shift(1)
    daily_agg['prevLow'] = daily_agg['day_low'].shift(1)
    
    # Map previous day data back to each bar
    prev_day_map = daily_agg.set_index('date')
    df['prevClose'] = df['date'].map(lambda x: prev_day_map.loc[x, 'prevClose'] if x in prev_day_map.index else np.nan)
    df['prevHigh'] = df['date'].map(lambda x: prev_day_map.loc[x, 'prevHigh'] if x in prev_day_map.index else np.nan)
    df['prevLow'] = df['date'].map(lambda x: prev_day_map.loc[x, 'prevLow'] if x in prev_day_map.index else np.nan)
    df['dayOpen'] = df['date'].map(lambda x: prev_day_map.loc[x, 'day_open'] if x in prev_day_map.index else np.nan)
    
    # Compute the midpoint between previous high and low
    bias_mid = (df['prevHigh'] + df['prevLow']) / 2
    
    # Classify bias direction: bullish when dayOpen exceeds both prevClose and the midpoint, bearish when below both
    bias_up = df['dayOpen'] > df['prevClose'] & (df['dayOpen'] > bias_mid)
    bias_down = df['dayOpen'] < df['prevClose'] & (df['dayOpen'] < bias_mid)
    df['bias'] = np.select([bias_up, bias_down], ['Bullish', 'Bearish'], default='Neutral')
    
    # Track FVG state across iterations
    ig_active = False
    ig_direction = 0
    ig_c1_high = np.nan
    ig_c1_low = np.nan
    ig_validation_end = np.nan
    
    trade_num = 0
    entries = []
    
    n = len(df)
    
    for i in range(2, n):
        bias_val = df['bias'].iloc[i]
        
        # Identify bullish FVG where prior high stays below current low
        if df['high'].iloc[i-2] < df['low'].iloc[i]:
            ig_active = True
            ig_direction = 1
            ig_c1_high = df['high'].iloc[i-2]
            ig_c1_low = df['low'].iloc[i-2]
            ig_c3_high = df['high'].iloc[i]
            ig_c3_low = df['low'].iloc[i]
            ig_validation_end = i + 4
        
        # Identify bearish FVG where prior low exceeds current high
        elif df['low'].iloc[i-2] > df['high'].iloc[i]:
            ig_active = True
            ig_direction = -1
            ig_c1_high = df['high'].iloc[i-2]
            ig_c1_low = df['low'].iloc[i-2]
            ig_c3_high = df['high'].iloc[i]
            ig_c3_low = df['low'].iloc[i]
            ig_validation_end = i + 4
        
        validated = False
        if ig_active and i <= ig_validation_end:
            if ig_direction == 1 and df['close'].iloc[i] < ig_c1_high:
                validated = True
            elif ig_direction == -1 and df['close'].iloc[i] > ig_c1_low:
                validated = True
        
        system_entry_long = validated and ig_direction == -1
        system_entry_short = validated and ig_direction == 1
        
        if system_entry_long and bias_val == 'Bullish':
            trade_num += 1
            entry_price = df['close'].iloc[i]
            entry_ts = int(df['time'].iloc[i])
            entry_time = datetime.fromtimestamp(entry_ts, tz=timezone.utc).isoformat()
            
            entries.append({
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': entry_ts,
                'entry_time': entry_time,
                'entry_price_guess': entry_price,
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': entry_price,
                'raw_price_b': entry_price
            })
        
        if system_entry_short and bias_val == 'Bearish':
            trade_num += 1
            entry_price = df['close'].iloc[i]
            entry_ts = int(df['time'].iloc[i])
            entry_time = datetime.fromtimestamp(entry_ts, tz=timezone.utc).isoformat()
            
            entries.append({
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': entry_ts,
                'entry_time': entry_time,
                'entry_price_guess': entry_price,
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': entry_price,
                'raw_price_b': entry_price
            })
        
        if validated:
            ig_active = False
    
    return entries

I need to check how the bias condition integrates with the FVG validation. The original script evaluates bias after each bar's data updates, so for any given day, the bias value is constant across all intraday bars. This means I should verify the bias logic matches the intended behavior where bullish or bearish bias acts as a filter on the FVG signals.

For the entry conditions, when system_entry_long triggers (validated with ig_direction == -1), it checks for bullish bias before entering long. Similarly, system_entry_short (validated with ig_direction == 1) requires bearish bias before entering short. The bias classification happens through the np.select statement I created, which maps bullish conditions to 'Bullish' and bearish conditions to 'Bearish'.

I'm now ready to implement the full function, checking that all required fields are properly initialized in the return structure.

