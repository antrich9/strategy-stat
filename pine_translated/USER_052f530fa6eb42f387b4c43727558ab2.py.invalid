import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    df = df.copy()
    
    # Convert to datetime and extract date
    df['datetime'] = pd.to_datetime(df['time'], unit='s', utc=True)
    df['date'] = df['datetime'].dt.date
    
    # Compute daily data for previous day values
    # Current day's open is the first bar's open of that day
    daily_groups = df.groupby('date').agg(
        day_open=('open', 'first'),
        day_high=('high', 'max'),
        day_low=('low', 'min'),
        day_close=('close', 'last'),
        day_time_first=('time', 'min'),
        day_time_last=('time', 'last')
    ).reset_index()
    
    # Use shift to get previous day's values
    daily_groups['prevClose'] = daily_groups['day_close'].shift(1)
    daily_groups['prevHigh'] = daily_groups['day_high'].shift(1)
    daily_groups['prevLow'] = daily_groups['day_low'].shift(1)
    
    # Create previous day data lookup keyed by date
    prev_day_lookup = daily_groups.set_index('date')[['prevClose', 'prevHigh', 'prevLow']].to_dict('index')
    
    # Map previous day values back to each bar
    df['prevClose'] = df['date'].map(lambda x: prev_day_lookup.get(x, {}).get('prevClose', np.nan))
    df['prevHigh'] = df['date'].map(lambda x: prev_day_lookup.get(x, {}).get('prevHigh', np.nan))
    df['prevLow'] = df['date'].map(lambda x: prev_day_lookup.get(x, {}).get('prevLow', np.nan))
    df['dayOpen'] = df['date'].map(lambda x: prev_day_lookup.get(x, {}).get('day_open', np.nan))
    
    # Calculate BIAS conditions
    midpoint = (df['prevHigh'] + df['prevLow']) / 2
    biasUp = df['dayOpen'] > df['prevClose'] & (df['dayOpen'] > midpoint)
    biasDown = df['dayOpen'] < df['prevClose'] & (df['dayOpen'] < midpoint)
    df['bias'] = np.where(biasUp, 'Bullish', np.where(biasDown, 'Bearish', 'Neutral'))
    
    # Initialize state tracking variables
    ig_active = False
    ig_c1_high = np.nan
    ig_c1_low = np.nan
    ig_direction = 0
    ig_validation_end = np.nan
    
    trade_num = 0
    entries = []
    
    # Iterate through each row to detect and validate FVG patterns
    n = len(df)
    for i in range(n):
        # Get previous bar index
        prev_idx = i - 1
        
        # Detect bullish FVG: candle 2 bars back has high that stays below current low
        if i >= 2 and df['high'].iloc[i-2] < df['low'].iloc[i]:
            ig_active = True
            ig_direction = 1
            ig_c1_high = df['high'].iloc[i-2]
            ig_c1_low = df['low'].iloc[i-2]
            ig_c3_high = df['high'].iloc[i]
            ig_c3_low = df['low'].iloc[i]
            ig_validation_end = i + 4
        
        # Detect bearish FVG: candle 2 bars back has low that exceeds current high
        elif i >= 2 and df['low'].iloc[i-2] > df['high'].iloc[i]:
            ig_active = True
            ig_direction = -1
            ig_c1_high = df['high'].iloc[i-2]
            ig_c1_low = df['low'].iloc[i-2]
            ig_c3_high = df['high'].iloc[i]
            ig_c3_low = df['low'].iloc[i]
            ig_validation_end = i + 4
        
        # Validate FVG and generate entry signals
        validated = False
        if ig_active and i <= ig_validation_end:
            if ig_direction == 1 and df['close'].iloc[i] < ig_c1_high:
                validated = True
            if ig_direction == -1 and df['close'].iloc[i] > ig_c1_low:
                validated = True

        # Entry conditions: long when bearish FVG validates with bullish bias, short when bullish FVG validates with bearish bias
        if validated and not ig_active:
            ig_active = False
        
        # Determine entry direction and bias alignment
        system_entry_long = validated and ig_direction == -1
        system_entry_short = validated and ig_direction == 1
        bias_value = df['bias'].iloc[i] if i < len(df) else 'Neutral'
        
        # Execute long entry on bullish bias confirmation
        if system_entry_long and bias_value == 'Bullish':
            trade_num += 1
            entry_price = df['close'].iloc[i]
            entry_ts = df['time'].iloc[i]
            entry_time = datetime.fromtimestamp(entry_ts, tz=timezone.utc).isoformat()
            
            entries.append({
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': entry_ts,
                'entry_time': entry_time,
                'entry_price_guess': entry_price,
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': entry_price,
                'raw_price_b': entry_price
            })
        
        # Execute short entry on bearish bias confirmation
        if system_entry_short and bias_value == 'Bearish':
            trade_num += 1
            entry_price = df['close'].iloc[i]
            entry_ts = df['time'].iloc[i]
            entry_time = datetime.fromtimestamp(entry_ts, tz=timezone.utc).isoformat()
            
            entries.append({
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': entry_ts,
                'entry_time': entry_time,
                'entry_price_guess': entry_price,
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': entry_price,
                'raw_price_b': entry_price
            })
        
        # Clear active state after validation
        if validated:
            ig_active = False
    
    return entries

