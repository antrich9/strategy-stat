Let me write the Python code:

import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    
    # Convert timestamp to datetime for grouping by day
    df = df.copy()
    df['datetime'] = pd.to_datetime(df['time'], unit='s', utc=True)
    df['date'] = df['datetime'].dt.date
    
    # Calculate previous day OHLC using shift to access the completed day's values
    daily_agg = df.groupby('date').agg({
        'open': 'first',
        'high': 'max',
        'low': 'min',
        'close': 'last',
        'time': 'min'
    }).reset_index()
    
    daily_agg['prevHigh'] = daily_agg['high'].shift(1)
    daily_agg['prevLow'] = daily_agg['low'].shift(1)
    daily_agg['prevClose'] = daily_agg['close'].shift(1)
    daily_agg['dayOpen'] = daily_agg['open']
    
    # Merge previous day data back to intraday df
    df = df.merge(daily_agg[['date', 'prevHigh', 'prevLow', 'prevClose', 'dayOpen']], on='date', how='left')
    
    # Calculate BIAS
    df['biasMidpoint'] = (df['prevHigh'] + df['prevLow']) / 2
    df['biasUp'] = df['dayOpen'] > df['prevClose'] & df['dayOpen'] > df['biasMidpoint']
    df['biasDown'] = df['dayOpen'] < df['prevClose'] & df['dayOpen'] < df['biasMidpoint']
    df['bias'] = np.where(df['biasUp'], 'Bullish', np.where(df['biasDown'], 'Bearish', 'Neutral'))
    
    # FVG detection
    df['bullishFVG1'] = (df['high'].shift(2) < df['low']) & (df['high'].shift(2) != df['high'].shift(2))
    df['bearishFVG1'] = (df['low'].shift(2) > df['high']) & (df['low'].shift(2) != df['low'].shift(2))
    
    # Initialize state variables
    df['ig_active'] = False
    df['ig_direction'] = 0
    df['validated'] = False
    
    # State machine logic
    for i in range(2, len(df)):
        if df.loc[i, 'bullishFVG1'] and not df.loc[i-1, 'ig_active']:
            df.loc[i, 'ig_active'] = True
            df.loc[i, 'ig_direction'] = 1
        elif df.loc[i, 'bearishFVG1'] and not df.loc[i-1, 'ig_active']:
            df.loc[i, 'ig_active'] = True
            df.loc[i, 'ig_direction'] = -1
        elif df.loc[i, 'validated']:
            df.loc[i, 'ig_active'] = False
    
    # Entry conditions
    df['system_entry_long'] = df['validated'] & (df['ig_direction'] == -1)
    df['system_entry_short'] = df['validated'] & (df['ig_direction'] == 1)
    
    # Generate entry signals
    df['entry_long'] = df['system_entry_long'] & (df['bias'] == 'Bullish')
    df['entry_short'] = df['system_entry_short'] & (df['bias'] == 'Bearish')
    
    # Create entry signals list
    entries = []
    for i in range(len(df)):
        if df.loc[i, 'entry_long']:
            entries.append({
                'trade_num': len(entries) + 1,
                'direction': 'long',
                'entry_ts': int(df.loc[i, 'time']),
                'entry_time': datetime.fromtimestamp(df.loc[i, 'time'], tz=timezone.utc).isoformat(),
                'entry_price': df.loc[i, 'close'],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price': 0.0,
                'raw_price_a': df.loc[i, 'close'],
                'raw_price_b': df.loc[i, 'close']
            })
        if df.loc[i, 'entry_short']:
            entries.append({
                'trade_num': len(entries) + 1,
                'direction': 'short',
                'entry_ts': int(df.loc[i, 'time']),
                'entry_time': datetime.fromtimestamp(df.loc[i, 'time'], tz=timezone.utc).isoformat(),
                'entry_price': df.loc[i, 'close'],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price': 0.0,
                'raw_price_a': df.loc[i, 'close'],
                'raw_price_b': df.loc[i, 'close']
            })
    
    return entries

