    df_daily['dailyLow22'] = df_daily['low'].shift(2)
    
    df_daily['is_swing_high11'] = (df_daily['dailyHigh21'] < df_daily['dailyHigh22']) & \
                                  (df_daily['dailyHigh11'].shift(3) < df_daily['dailyHigh22']) & \
                                  (df_daily['dailyHigh11'].shift(4) < df_daily['dailyHigh22'])
    df_daily['is_swing_low11'] = (df_daily['dailyLow21'] > df_daily['dailyLow22']) & \
                                 (df_daily['dailyLow11'].shift(3) > df_daily['dailyLow22']) & \
                                 (df_daily['dailyLow11'].shift(4) > df_daily['dailyLow22'])
    
    # Determine last swing type
    df_daily['lastSwingType11'] = 'none'
    df_daily.loc[df_daily['is_swing_high11'], 'lastSwingType11'] = 'dailyHigh'
    df_daily.loc[df_daily['is_swing_low11'], 'lastSwingType11'] = 'dailyLow'
    df_daily['lastSwingType11'] = df_daily['lastSwingType11'].replace('none', np.nan).ffill().fillna('none')
    
    # Forward fill swing high/low prices
    df_daily['last_swing_high11'] = df_daily['high'].where(df_daily['is_swing_high11']).ffill()
    df_daily['last_swing_low11'] = df_daily['low'].where(df_daily['is_swing_low11']).ffill()
    
