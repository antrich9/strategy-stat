import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    
    # Convert time to datetime
    df = df.copy()
    df['datetime'] = pd.to_datetime(df['time'], unit='s', utc=True)
    df = df.set_index('datetime')
    
    # Resample to daily
    daily = df.resample('D').agg({
        'open': 'first',
        'high': 'max',
        'low': 'min',
        'close': 'last'
    }).dropna()
    
    # Resample to 4H
    hours_4 = df.resample('4h').agg({
        'open': 'first',
        'high': 'max',
        'low': 'min',
        'close': 'last',
        'volume': 'sum'
    }).dropna()
    
    # Calculate swing high/low
    daily['swing_high'] = (daily['high'] > daily['high'].shift(1)) & (daily['high'] > daily['high'].shift(-1))
    daily['swing_low'] = (daily['low'] < daily['low'].shift(1)) & (daily['low'] < daily['low'].shift(-1))
    
    # Detect new day and sweeps
    df['new_day'] = df.index.to_series().diff().dt.days > 0
    df['sweep_high'] = (df['high'] > df['high'].shift(1)) & df['new_day']
    df['sweep_low'] = (df['low'] < df['low'].shift(1)) & df['new_day']
    
    # Calculate FVG conditions
    hours_4['fvg_bullish'] = hours_4['low'] > hours_4['high'].shift(2)
    hours_4['fvg_bearish'] = hours_4['high'] < hours_4['low'].shift(2)
    
    # Trading window (9:30 AM - 4:00 PM EST)
    df['trading_window'] = (df.index.hour >= 9) & (df.index.hour < 16)
    
    # Calculate filters
    df['volume_filter'] = df['volume'] > df['volume'].rolling(20).mean()
    df['atr_filter'] = df['high'] - df['low'] > df['high'] - df['low'].rolling(20).mean()
    df['trend_filter'] = df['close'] > df['close'].rolling(50).mean()
    
    # Merge 4H data back to original timeframe
    df = df.merge(hours_4[['fvg_bullish', 'fvg_bearish']], left_index=True, right_index=True, how='left')
    
    # Generate entries
    entries = []
    trade_num = 1
    
    for i in range(len(df)):
        if df['trading_window'].iloc[i]:
            if df['fvg_bullish'].iloc[i] and df['volume_filter'].iloc[i] and df['atr_filter'].iloc[i] and df['trend_filter'].iloc[i]:
                entries.append({
                    'trade_num': trade_num,
                    'direction': 'long',
                    'entry_ts': df['time'].iloc[i],
                    'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                    'entry_price_guess': df['close'].iloc[i],
                    'exit_ts': 0,
                    'exit_time': '',
                    'exit_price_guess': 0.0,
                    'raw_price_a': df['close'].iloc[i],
                    'raw_price_b': df['close'].iloc[i]
                })
                trade_num += 1
            elif df['fvg_bearish'].iloc[i] and df['volume_filter'].iloc[i] and df['atr_filter'].iloc[i] and not df['trend_filter'].iloc[i]:
                entries.append({
                    'trade_num': trade_num,
                    'direction': 'short',
                    'entry_ts': df['time'].iloc[i],
                    'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                    'entry_price_guess': df['close'].iloc[i],
                    'exit_ts': 0,
                    'exit_time': '',
                    'exit_price_guess': 0.0,
                    'raw_price_a': df['close'].iloc[i],
                    'raw_price_b': df['close'].iloc[i]
                })
                trade_num += 1
    
    return entries

    is_swing_high11 = dailyHigh21 < dailyHigh22 and dailyHigh11[3] < dailyHigh22 and dailyHigh11[4] < dailyHigh22
    is_swing_low11 = dailyLow21 > dailyLow22 and dailyLow11[3] > dailyLow22 and dailyLow11[4] > dailyLow22
    
    return [is_swing_high11, is_swing_low11]

I need to calculate swing highs and lows using the daily data. A swing high occurs when the current daily high is lower than the previous day's high, and the daily highs from 3 and 4 bars back are also lower than the previous day's high. Similarly, swing lows are detected when the current daily low is higher than the previous day's low, with the daily lows from 3 and 4 bars back also higher.

After identifying these patterns, I track the most recent swing type and update it accordingly. I also incorporate sweep detection logic to identify when highs or lows are being swept, then apply multiple confirmation filters including volume thresholds, ATR-based volatility checks, and trend direction validation. Finally, I check for fair value gap conditions that would indicate institutional order flow imbalances. I need to reconsider the timeframe alignment issue. The 4H candles shouldn't automatically align with the 15min bars, so I need to be more careful about how I'm pulling the historical data. Looking at the security calls more closely, there's a mix of lookahead settings being used—the current 4H bar uses `lookahead_on`, but the historical bars use `lookahead_off`. This suggests the code is intentionally handling real-time vs historical data differently.

