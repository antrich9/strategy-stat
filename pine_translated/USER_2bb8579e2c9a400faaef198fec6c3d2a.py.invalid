import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.

    Returns list of dicts:
    [{'trade_num': int, 'direction': 'long' or 'short',
      'entry_ts': int, 'entry_time': str,
      'entry_price_guess': float,
      'exit_ts': 0, 'exit_time': '', 'exit_price_guess': 0.0,
      'raw_price_a': float, 'raw_price_b': float}]
    """
    
    # Convert time to datetime for time-based filtering
    df['datetime'] = pd.to_datetime(df['time'], unit='ms', utc=True)
    
    # Extract hour and minute, accounting for DST
    # In Pine Script, is_dst check:
    # is_dst = (month >= 3 and (month == 3 and dayofweek == dayofweek.sunday and dayofmonth >= 25 or month > 3)) and
    #          (month <= 10 and (month == 10 and dayofweek == dayofweek.sunday and dayofmonth < 25 or month < 10))
    
    # Python equivalent for DST check
    def is_dst(dt):
        # DST: Starts last Sunday in March at 1am UTC, ends last Sunday in October at 1am UTC
        year = dt.year
        # Find last Sunday of March
        march_31 = datetime(year, 3, 31)
        days_since_sunday = (march_31.weekday() + 1) % 7  # 0=Monday, 6=Sunday
        last_sunday_march = 31 - days_since_sunday
        dst_start = datetime(year, 3, last_sunday_march, 1, 0, tzinfo=timezone.utc)
        
        # Find last Sunday of October
        oct_31 = datetime(year, 10, 31)
        days_since_sunday = (oct_31.weekday() + 1) % 7
        last_sunday_oct = 31 - days_since_sunday
        dst_end = datetime(year, 10, last_sunday_oct, 1, 0, tzinfo=timezone.utc)
        
        return dst_start <= dt < dst_end
    
    # Adjust for DST - add 1 hour if DST
    df['datetime_adj'] = df['datetime'].apply(lambda x: x + pd.Timedelta(hours=1) if is_dst(x) else x)
    
    # Extract hour and minute
    df['hour'] = df['datetime_adj'].dt.hour
    df['minute'] = df['datetime_adj'].dt.minute
    
    # Time window conditions
    # Window 1: 07:00 - 10:59
    window1_start = 7
    window1_end_hour = 10
    window1_end_minute = 59
    
    in_window1 = ((df['hour'] > window1_start) | 
                  ((df['hour'] == window1_start) & (df['minute'] >= 0))) & \
                 ((df['hour'] < window1_end_hour) | 
                  ((df['hour'] == window1_end_hour) & (df['minute'] <= window1_end_minute)))
    
    # Window 2: 15:00 - 16:59
    window2_start = 15
    window2_end_hour = 16
    window2_end_minute = 59
    
    in_window2 = ((df['hour'] > window2_start) | 
                  ((df['hour'] == window2_start) & (df['minute'] >= 0))) & \
                 ((df['hour'] < window2_end_hour) | 
                  ((df['hour'] == window2_end_hour) & (df['minute'] <= window2_end_minute)))
    
    in_trading_window = in_window1 | in_window2
    
    # FVG conditions (Bullish and Bearish Fair Value Gaps)
    # inp1, inp2, inp3 are all false, so volfilt, atrfilt, locfiltb, locfilts are all true
    # bfvg = low > high[2]
    # sfvg = high < low[2]
    
    bfvg = df['low'] > df['high'].shift(2)
    sfvg = df['high'] < df['low'].shift(2)
    
    # Entry conditions
    long_condition = in_trading_window & bfvg
    short_condition = in_trading_window & sfvg
    
    # Generate entries
    entries = []
    trade_num = 1
    
    for i in range(len(df)):
        if long_condition.iloc[i]:
            ts = df['time'].iloc[i]
            entries.append({
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': ts,
                'entry_time': datetime.fromtimestamp(ts / 1000, tz=timezone.utc).isoformat(),
                'entry_price_guess': df['close'].iloc[i],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': df['close'].iloc[i],
                'raw_price_b': df['close'].iloc[i]
            })
            trade_num += 1
        elif short_condition.iloc[i]:
            ts = df['time'].iloc[i]
            entries.append({
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': ts,
                'entry_time': datetime.fromtimestamp(ts / 1000, tz=timezone.utc).isoformat(),
                'entry_price_guess': df['close'].iloc[i],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': df['close'].iloc[i],
                'raw_price_b': df['close'].iloc[i]
            })
            trade_num += 1
    
    return entries

