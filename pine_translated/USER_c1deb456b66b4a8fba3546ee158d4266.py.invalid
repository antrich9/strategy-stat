import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    """
    df columns: time(int unix ts), open(float), high(float), low(float), close(float), volume(float)
    Rows sorted ascending by time (oldest first). Index is 0-based int.
    Returns list of dicts with entry signals.
    """
    # Initialize result list
    results = []
    
    # Strategy parameters (hardcoded from Pine Script)
    atrLength = 14
    ciLength = 14
    ciThreshold = 61.8
    lengthMD = 10
    atrMultiplier = 1.5
    input_lookback = 20
    input_retSince = 2
    input_retValid = 2
    input_repType = 'On'  # Can be 'On', 'Off: Candle Confirmation', 'Off: High & Low'
    
    # Calculate basic indicators
    # Choppiness Index calculation
    high_low_range = df['high'].rolling(window=ciLength).max() - df['low'].rolling(window=ciLength).min()
    atr_sum = df['close'].diff().abs().rolling(window=ciLength).mean()
    ci = 100 * np.log10(atr_sum / high_low_range) / np.log10(ciLength)
    
    # ATR calculation
    tr = np.maximum(
        df['high'] - df['low'],
        np.maximum(
            abs(df['high'] - df['close'].shift(1)),
            abs(df['low'] - df['close'].shift(1))
        )
    )
    atr = tr.rolling(window=atrLength).mean()
    
    # McGinley Dynamic calculation
    mgd = df['close'].copy()
    for i in range(1, len(df)):
        mgd.iloc[i] = mgd.iloc[i-1] + (df['close'].iloc[i] - mgd.iloc[i-1]) / (0.0 if mgd.iloc[i-1] == 0 else (lengthMD * (df['close'].iloc[i] / mgd.iloc[i-1]) ** 4))
    
    # Pivot points detection
    pl = df['low'].rolling(window=input_lookback + 1).min()
    ph = df['high'].rolling(window=input_lookback + 1).max()
    
    # Support and resistance levels
    support = pl.rolling(window=input_lookback).min()
    resistance = ph.rolling(window=input_lookback).max()
    
    # Breakout detection
    support_break = df['close'] < support
    resistance_break = df['close'] > resistance
    
    # Retest conditions (simplified from Pine Script logic)
    # Support retest: price comes back to test broken support
    support_retest = (df['close'] < support) & (df['close'].shift(1) >= support)
    
    # Resistance retest: price comes back to test broken resistance
    resistance_retest = (df['close'] > resistance) & (df['close'].shift(1) <= resistance)
    
    # Entry signals
    long_entry = support_break & support_retest
    short_entry = resistance_break & resistance_retest
    
    # Apply choppiness filter (only trade in non-choppy market)
    long_entry = long_entry & (ci < ciThreshold)
    short_entry = short_entry & (ci < ciThreshold)
    
    # Generate trade list
    trade_num = 1
    for i in range(len(df)):
        if long_entry.iloc[i]:
            results.append({
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': int(df['time'].iloc[i]),
                'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                'entry_price': df['close'].iloc[i],
                'atr': atr.iloc[i],
                'stop_loss': df['close'].iloc[i] - (atr.iloc[i] * atrMultiplier),
                'take_profit': df['close'].iloc[i] + (atr.iloc[i] * atrMultiplier * 1.5)
            })
            trade_num += 1
        elif short_entry.iloc[i]:
            results.append({
                'trade_num': trade_num,
                'direction': 'short',
                'entry_ts': int(df['time'].iloc[i]),
                'entry_time': datetime.fromtimestamp(df['time'].iloc[i], tz=timezone.utc).isoformat(),
                'entry_price': df['close'].iloc[i],
                'atr': atr.iloc[i],
                'stop_loss': df['close'].iloc[i] + (atr.iloc[i] * atrMultiplier),
                'take_profit': df['close'].iloc[i] - (atr.iloc[i] * atrMultiplier * 1.5)
            })
            trade_num += 1
    
    return results
