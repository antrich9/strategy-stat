import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    atrLength = 14
    ciLength = 14
    ciThreshold = 61.8
    lengthMD = 10
    atrMultiplier = 1.5
    lookback = 20
    retSince = 2
    retValid_limit = 2
    repaint_mode = 'On'  # 'On', 'Off: Candle Confirmation', 'Off: High & Low'
    
    n = len(df)
    results = []
    trade_num = 1
    
    # True Range
    tr1 = df['high'] - df['low']
    tr2 = np.abs(df['high'] - df['close'].shift(1))
    tr3 = np.abs(df['low'] - df['close'].shift(1))
    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
    
    # Wilder ATR
    atr = pd.Series(np.nan, index=df.index)
    atr.iloc[atrLength - 1] = tr.iloc[:atrLength].mean()
    for i in range(atrLength, n):
        atr.iloc[i] = (atr.iloc[i-1] * (atrLength - 1) + tr.iloc[i]) / atrLength
    
    # Choppiness Index
    ci_atr_sum = tr.rolling(window=ciLength).mean()
    highest_high = df['high'].rolling(window=ciLength).max()
    lowest_low = df['low'].rolling(window=ciLength).min()
    high_low_range = highest_high - lowest_low
    ci = pd.Series(np.nan, index=df.index)
    valid_ci = ci_atr_sum.fillna(1) * high_low_range.fillna(1) > 0
    ci[valid_ci] = 100 * np.log10(ci_atr_sum[valid_ci] / high_low_range[valid_ci]) / np.log10(ciLength)
    
    # McGinley Dynamic
    mgd = pd.Series(np.nan, index=df.index)
    mgd.iloc[0] = df['close'].iloc[0]
    for i in range(1, n):
        prev_mgd = mgd.iloc[i-1]
        price = df['close'].iloc[i]
        k = (price / prev_mgd) ** 4 if prev_mgd != 0 else 0
        mgd.iloc[i] = prev_mgd + (price - prev_mgd) / (lengthMD * k) if k != 0 else prev_mgd
    
    # Pivot points
    pl = pd.Series(np.nan, index=df.index)
    ph = pd.Series(np.nan, index=df.index)
    for i in range(lookback, n - lookback):
        window_low = df['low'].iloc[i-lookback:i+lookback+1].min()
        window_high = df['high'].iloc[i-lookback:i+lookback+1].max()
        if df['low'].iloc[i] == window_low:
            pl.iloc[i] = df['low'].iloc[i]
        if df['high'].iloc[i] == window_high:
            ph.iloc[i] = df['high'].iloc[i]
    
    # Support/Resistance boxes
    sBot_series = pd.Series(np.nan, index=df.index)
    sTop_series = pd.Series(np.nan, index=df.index)
    rBot_series = pd.Series(np.nan, index=df.index)
    rTop_series = pd.Series(np.nan, index=df.index)
    
    for i in range(lookback, n):
        if not np.isnan(pl.iloc[i]):
            s_yLoc = df['low'].iloc[i-lookback-1] if df['low'].iloc[i-lookback-1] > df['low'].iloc[i-lookback+1] else df['low'].iloc[i-lookback+1]
            sBot_series.iloc[i] = df['low'].iloc[i-1]
            sTop_series.iloc[i] = s_yLoc
        if not np.isnan(ph.iloc[i]):
            r_yLoc = df['high'].iloc[i-lookback-1] if df['high'].iloc[i-lookback-1] > df['high'].iloc[i-lookback+1] else df['high'].iloc[i-lookback+1]
            rBot_series.iloc[i] = r_yLoc
            rTop_series.iloc[i] = df['high'].iloc[i-1]
    
    # Breakout detection
    sBreak = pd.Series(False, index=df.index)
    rBreak = pd.Series(False, index=df.index)
    
    for i in range(1, n):
        sBot_val = sBot_series.iloc[i] if not np.isnan(sBot_series.iloc[i]) else np.inf
        rTop_val = rTop_series.iloc[i] if not np.isnan(rTop_series.iloc[i]) else -np.inf
        
        if df['close'].iloc[i] < sBot_val and df['close'].iloc[i-1] >= sBot_val:
            sBreak.iloc[i] = True
        if df['close'].iloc[i] > rTop_val and df['close'].iloc[i-1] <= rTop_val:
            rBreak.iloc[i] = True
    
    # Retest logic
    long_entry = pd.Series(False, index=df.index)
    short_entry = pd.Series(False, index=df.index)
    
    for i in range(lookback, n):
        if sBreak.iloc[i]:
            sTop_val = sTop_series.iloc[i] if not np.isnan(sTop_series.iloc[i]) else np.inf
            if df['close'].iloc[i] >= sTop_val and df['close'].iloc[i-1] < sTop_val:
                long_entry.iloc[i] = True
        if rBreak.iloc[i]:
            rBot_val = rBot_series.iloc[i] if not np.isnan(rBot_series.iloc[i]) else -np.inf
            if df['close'].iloc[i] <= rBot_val and df['close'].iloc[i-1] > rBot_val:
                short_entry.iloc[i] = True
    
    return long_entry, short_entry, atr, ci, mgd

