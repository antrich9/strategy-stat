import pandas as pd
import numpy as np
from datetime import datetime, timezone

def generate_entries(df: pd.DataFrame) -> list:
    # Parameters
    atrLength = 14
    ciLength = 14
    ciThreshold = 61.8
    lengthMD = 10
    atrMultiplier = 1.5
    lookback = 20
    retSince = 2
    retValid_limit = 2
    repaint_mode = 'On'
    tradeDirection = 'Both'
    
    n = len(df)
    results = []
    trade_num = 1
    
    # True Range
    tr1 = df['high'] - df['low']
    tr2 = np.abs(df['high'] - df['close'].shift(1))
    tr3 = np.abs(df['low'] - df['close'].shift(1))
    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
    
    # Wilder ATR
    atr = pd.Series(np.nan, index=df.index)
    atr.iloc[atrLength - 1] = tr.iloc[:atrLength].mean()
    for i in range(atrLength, n):
        atr.iloc[i] = (atr.iloc[i-1] * (atrLength - 1) + tr.iloc[i]) / atrLength
    
    # Choppiness Index
    ci_atr_sum = tr.rolling(window=ciLength).mean()
    high_low_range = df['high'].rolling(window=ciLength).max() - df['low'].rolling(window=ciLength).min()
    ci = pd.Series(np.nan, index=df.index)
    valid_ci_mask = high_low_range != 0
    ci_values = 100 * np.log10(ci_atr_sum / high_low_range) / np.log10(ciLength)
    ci[valid_ci_mask] = ci_values[valid_ci_mask]
    
    # McGinley Dynamic
    mgd = pd.Series(np.nan, index=df.index)
    mgd.iloc[0] = df['close'].iloc[0]
    k = lengthMD * ((df['close'] / mgd.shift(1).replace(0, np.nan)) ** 4)
    mgd = mgd.shift(1) + (df['close'] - mgd.shift(1)) / k.replace([np.inf, -np.inf], np.nan)
    mgd.iloc[0] = df['close'].iloc[0]
    
    # Pivot points
    pl = df['low'].shift(lookback).rolling(window=2*lookback+1).min()
    ph = df['high'].shift(lookback).rolling(window=2*lookback+1).max()
    
    # Box values
    sBot = pl.copy()
    sTop = df['low'].shift(lookback+1)
    rBot = df['high'].shift(lookback+1)
    rTop = ph.copy()
    
    # Detect breakouts
    sBreak = df['close'] < sBot
    rBreak = df['close'] > rTop
    
    # Handle direction filtering based on tradeDirection parameter
    if tradeDirection == "Long":
        long_entry = pd.Series(True, index=df.index)
        short_entry = pd.Series(False, index=df.index)
    elif tradeDirection == "Short":
        long_entry = pd.Series(False, index=df.index)
        short_entry = pd.Series(True, index=df.index)
    else:  # "Both"
        long_entry = pd.Series(True, index=df.index)
        short_entry = pd.Series(True, index=df.index)
    
    results = []
    trade_num = 1
    
    # Identify support and resistance breakouts
    sBreak_mask = (df['close'] < sBot) & sBot.notna()
    rBreak_mask = (df['close'] > rTop) & rTop.notna()
    
    # Track when new breakouts occur
    sBreak_new = sBreak_mask & ~sBreak_mask.shift(1).fillna(False)
    rBreak_new = rBreak_mask & ~rBreak_mask.shift(1).fillna(False)
    
    # Initialize entry flags
    sRetValid = pd.Series(False, index=df.index)
    rRetValid = pd.Series(False, index=df.index)
    
    # Calculate support retest conditions
    sRetActive_1 = (df['high'] >= sTop) & (df['close'] <= sBot)
    sRetActive_2 = (df['high'] >= sTop) & (df['close'] >= sBot) & (df['close'] <= sTop)
    sRetActive_3 = (df['high'] >= sBot) & (df['high'] <= sTop)
    sRetActive_4 = (df['high'] >= sBot) & (df['high'] <= sTop) & (df['close'] < sBot)
    
    # Combine support retest conditions
    sRetActive = sRetActive_1 | sRetActive_2 | sRetActive_3 | sRetActive_4
    
    # Track support retests by counting bars since last breakout
    sBars_since_breakout = np.full(n, -1)
    sRetOccurred = np.full(n, np.nan, dtype=float)
    sRetEvent = np.full(n, False)
    sRetValue_arr = np.full(n, np.nan, dtype=float)
    
    for i in range(n):
        if sBreak_new.iloc[i]:
            sBars_since_breakout[i] = 0
            sRetOccurred[i] = np.nan
        elif sBars_since_breakout[i-1] >= 0 and not np.isnan(sBars_since_breakout[i-1]):
            sBars_since_breakout[i] = sBars_since_breakout[i-1] + 1
        elif sBreak_mask.iloc[i]:
            sBars_since_breakout[i] = 0
            sRetOccurred[i] = np.nan
        else:
            sBars_since_breakout[i] = -1
            sRetOccurred[i] = np.nan
    
    # Calculate resistance retest conditions
    rRetActive_1 = (df['low'] <= rBot) & (df['close'] >= rTop)
    rRetActive_2 = (df['low'] <= rBot) & (df['close'] <= rTop) & (df['close'] >= rBot)
    rRetActive_3 = (df['low'] <= rTop) & (df['low'] >= rBot)
    rRetActive_4 = (df['low'] <= rTop) & (df['low'] >= rBot) & (df['close'] > rTop)
    
    # Combine resistance retest conditions
    rRetActive = rRetActive_1 | rRetActive_2 | rRetActive_3 | rRetActive_4
    
    # Track resistance retests
    rBars_since_breakout = np.full(n, -1)
    rRetOccurred = np.full(n, np.nan, dtype=float)
    rRetEvent = np.full(n, False)
    rRetValue_arr = np.full(n, np.nan, dtype=float)
    
    for i in range(n):
        if rBreak_new.iloc[i]:
            rBars_since_breakout[i] = 0
            rRetOccurred[i] = np.nan
        elif rBars_since_breakout[i-1] >= 0 and not np.isnan(rBars_since_breakout[i-1]):
            rBars_since_breakout[i] = rBars_since_breakout[i-1] + 1
        elif rBreak_mask.iloc[i]:
            rBars_since_breakout[i] = 0
            rRetOccurred[i] = np.nan
        else:
            rBars_since_breakout[i] = -1
            rRetOccurred[i] = np.nan
    
    # Detect retest events (transition from False to True)
    sRetEvent[1:] = sRetActive.iloc[1:] & ~sRetActive.iloc[:-1].values
    rRetEvent[1:] = rRetActive.iloc[1:] & ~rRetActive.iloc[:-1].values
    
    sRetEvent[0] = sRetActive.iloc[0]
    rRetEvent[0] = rRetActive.iloc[0]
    
    # Record retest values at event points
    for i in range(n):
        if sRetEvent[i]:
            sRetValue_arr[i] = df['high'].iloc[i]
        if rRetEvent[i]:
            rRetValue_arr[i] = df['low'].iloc[i]
    
    # Retest event validity checks
    for i in range(1, n):
        if sRetEvent[i] and sBars_since_breakout[i] > retSince:
            sRetValid.iloc[i] = True
        if rRetEvent[i] and rBars_since_breakout[i] > retSince:
            rRetValid.iloc[i] = True
    
    # Long and short entry conditions
    long_cond = sRetValid
    short_cond = rRetValid
    
    # Apply trade direction filter
    if tradeDirection == "Long":
        long_entry = long_cond
        short_entry = pd.Series(False, index=df.index)
    elif tradeDirection == "Short":
        long_entry = pd.Series(False, index=df.index)
        short_entry = short_cond
    else:  # "Both"
        long_entry = long_cond
        short_entry = short_cond
    
    # Build results list for long entries
    for i in range(n):
        if long_entry.iloc[i]:
            ts = int(df['time'].iloc[i])
            results.append({
                'trade_num': trade_num,
                'direction': 'long',
                'entry_ts': ts,
                'entry_time': datetime.fromtimestamp(ts, tz=timezone.utc).isoformat(),
                'entry_price_guess': df['close'].iloc[i],
                'exit_ts': 0,
                'exit_time': '',
                'exit_price_guess': 0.0,
                'raw_price_a': df['close'].iloc[i],
                'raw_price_b': df['close'].iloc[i]
            })
            trade_num += 1
    
    # Build results list for short entries
    for i in range(n):
        if short_entry.iloc[i]:
            ts = int(df['time'].iloc[i])
            results.append({
                'trade_num': trade_num,
                'direction