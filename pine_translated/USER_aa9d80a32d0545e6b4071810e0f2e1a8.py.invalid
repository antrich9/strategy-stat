The `bull_filled` function uses `bull_vi[1]` to get the previous bar's signal. This makes sense because we want to detect when a previously identified FVG gets filled.

But for entry conditions, I think using the current bar's signal is more appropriate (enter when signal fires, not one bar later).

So I'll use `bull_vi_cond` directly.

Final implementation looks good. I'll use `bull_vi_cond` and `bear_vi_cond` for the entry conditions.

import pandas as pd
import numpy as np
from datetime import datetime, timezone
from dateutil.tz import gettz

def generate_entries(df: pd.DataFrame) -> list:
    ema_200 = df['high'].ewm(span=200, adjust=False).mean()
    
    if ema_200.isna().all():
        return []
    
    london_tz = gettz('Europe/London')
    times = pd.to_datetime(df['time'], unit='ms', utc=True).dt.tz_convert(london_tz)
    hours = times.dt.hour
    minutes = times.dt.minute
    
    in_trading_window = (
        ((hours == 7) & (minutes >= 45)) |
        ((hours >= 8) & (hours < 9)) |
        ((hours == 9) & (minutes <= 45)) |
        ((hours == 15) & (minutes >= 45)) |
        ((hours >= 16) & (hours < 17)) |
        ((hours == 17) & (minutes <= 45))
    )
    
    daily_data = df.resample('D', on='time').agg({'high': 'max', 'low': 'min'}).shift(1)
    daily_data.columns = ['prevDayHigh', 'prevDayLow']
    
    df = df.join(daily_data, how='left')
    
    df['period_start'] = (df['time'] // (240 * 60 * 1000)) * (240 * 60 * 1000)
    current_240 = df.groupby('period_start').agg({'high': 'max', 'low': 'min'})
    current_240 = current_240.rename(columns={'high': 'currentDayHigh', 'low': 'currentDayLow'})
    df = df.join(current_240, on='period_start', how='left')
    
    tr1 = df['high'] - df['low']
    tr2 = abs(df['close'] - df['high'])
    tr3 = abs(df['close'] - df['low'])
    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
    
    atr = pd.Series(index=tr.index, dtype=float)
    period = 200
    atr.iloc[period-1] = tr.iloc[:period].mean()
    
    for i in range(period, len(tr)):
        atr.iloc[i] = (atr.iloc[i-1] * (period - 1) + tr.iloc[i]) / period

I'm calculating the true range across three different measures, then computing a 200-period Wilder ATR using a recursive formula. The calculation starts from the initial average and updates it with each new value.

