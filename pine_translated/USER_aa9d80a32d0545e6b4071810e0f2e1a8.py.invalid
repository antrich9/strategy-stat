from dateutil.tz import gettz

def is_in_trading_window(df, tz_name='Europe/London'):
    tz = gettz(tz_name)
    times = pd.to_datetime(df['time'], unit='ms', utc=True).dt.tz_convert(tz)
    hours = times.dt.hour
    minutes = times.dt.minute
    
    morning = (hours == 7) & (minutes >= 45) | (hours == 8) | (hours == 9) & (minutes <= 45)
    afternoon = (hours == 15) & (minutes >= 45) | (hours == 16) & (minutes <= 45)
    
    return morning | afternoon

Now I need to handle the previous day high/low calculation using daily resampling.

def get_prev_day_levels(df):
    daily = df.resample('D', on='time').agg({'high': 'max', 'low': 'min'})
    daily['prevDayHigh'] = daily['high'].shift(1)
    daily['prevDayLow'] = daily['low'].shift(1)
    return daily[['prevDayHigh', 'prevDayLow']]

For the current 240-minute period, I need to group by 4-hour intervals and track the running high and low within each interval.

def get_current_240_levels(df):
    df = df.copy()
    df['period_start'] = (df['time'] // (240 * 60 * 1000)) * (240 * 60 * 1000)
    current = df.groupby('period_start').agg({'high': 'max', 'low': 'min'})
    current = current.rename(columns={'high': 'currentDayHigh', 'low': 'currentDayLow'})
    return current

