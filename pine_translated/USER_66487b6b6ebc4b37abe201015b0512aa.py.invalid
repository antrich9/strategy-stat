df['datetime'] = pd.to_datetime(df['time'], unit='s', utc=True)
df['date'] = df['datetime'].dt.date
daily = df.groupby('date').agg({'high': 'max', 'low': 'min'})
daily = daily.shift(1)  # shift to get previous day high/low
df['prevDayHigh'] = df['date'].map(daily['high'])
df['prevDayLow'] = df['date'].map(daily['low'])